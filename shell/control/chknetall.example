#!/bin/bash

workdir=$(cd $(dirname $0); pwd)
cd $workdir

cntexpr=`wc -l list.hosts | awk '{print $1}'`
cntall=`expr $cntexpr`

i=0
while [ $i -lt $cntall ]
do
        i=`expr $i + 1 `
        read hosts
		name=`ssh -n $hosts hostname`
		echo "("$i")" $hosts [$name]
		printf "ALL: "
        ssh -n $hosts 'netstat -an | grep ":80" | wc -l'
		printf "ESTABLISHED: "
        ssh -n $hosts 'netstat -an | grep ":80" | grep -v ESTABLISHED'
		printf "CLOSE_WAIT: "
        ssh -n $hosts 'netstat -an | grep ":80" | grep -v CLOSE_WAIT'
		printf "TIME_WAIT: "
        ssh -n $hosts 'netstat -an | grep ":80" | grep -v TIME_WAIT'
done < list.hosts
