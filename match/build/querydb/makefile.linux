querydb_build_dir/TradeHandler.cpp.o: ../../src/querydb/TradeHandler.cpp $(querydb_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src/querydb/TradeHandler.cpp -oquerydb_build_dir/TradeHandler.cpp.o

$(target): $(all_objs)
	$(LINK) $(LDFLAGS) -o $@ $(all_objs) $(all_libs) $(LIBS)

clean:
	-$(DEL) $(crypt_obj)
	-$(DEL) $(datastruct_obj)
	-$(DEL) $(function_obj)
	-$(DEL) $(logger_obj)
	-$(DEL) $(netstruct_obj)
	-$(DEL) $(field_obj)
	-$(DEL) $(ofapibase_obj)
	-$(DEL) $(dbconnect_obj)
	-$(DEL) $(querydb_obj)

	-$(DEL) $(target)
