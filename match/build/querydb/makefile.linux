	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src/querydb/App.cpp -oquerydb_build_dir/App.cpp.o
querydb_build_dir/FinishOrderHandler.cpp.o: ../../src/querydb/FinishOrderHandler.cpp $(querydb_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src/querydb/FinishOrderHandler.cpp -oquerydb_build_dir/FinishOrderHandler.cpp.o
