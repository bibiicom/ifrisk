
CPP=g++ -fpic -std=c++11
LINK=g++
LIB32=ar -ru
PREP=g++ -E -P
COPY=cp
DEL=rm
MAKE=make
ECHO=echo



	
	
ISLIB=N
DEFINES=-DLINUX -DGCC
target=././querydb

APPEND_CPPFLAGS=-g3 -gdwarf-2 -O0 -pthread -m64

PROFILE_CPPFLAGS=

WARNING_CPPFLAGS=-Wall -Wno-sign-compare

CPPFLAGS=   -DDEBUG_NOT_LOG $(APPEND_CPPFLAGS) $(PROFILE_CPPFLAGS) $(WARNING_CPPFLAGS) $(DEFINES)
LIBS= -lpthread -lrt  

DEBUG_LDFLAGS=-g -O0 -m64

MAP_LDFLAGS=

PROFILE_LDFLAGS=

WARNING_LDFLAGS=-Wall -Wno-sign-compare

LDFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS) $(WARNING_LDFLAGS)
LIBARFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)
DLLARFLAGS=    -shared -Wl,-Bsymbolic -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)

all: code

code: clearoutput $(target)

clearoutput:
	@$(ECHO) Compiling...
	-mkdir -p querydb_build_dir
	-mkdir -p ././
	
crypt_obj=querydb_build_dir/cryptUtility.cpp.o querydb_build_dir/Des.cpp.o querydb_build_dir/hexEncode.cpp.o querydb_build_dir/md5Handler.cpp.o 
crypt_includedir=-I../../src_base/crypt/.
datastruct_obj=querydb_build_dir/BigDigit.cpp.o querydb_build_dir/CDate.cpp.o querydb_build_dir/CErrorEngine.cpp.o querydb_build_dir/CSequence.cpp.o querydb_build_dir/CSVParser.cpp.o querydb_build_dir/CSVToField.cpp.o querydb_build_dir/FieldDescribe.cpp.o 
datastruct_includedir=-I../../src_base/datastruct/.
function_obj=querydb_build_dir/BaseFunction.cpp.o querydb_build_dir/Config.cpp.o querydb_build_dir/platform.cpp.o querydb_build_dir/printinfo.cpp.o querydb_build_dir/profile.cpp.o querydb_build_dir/utility.cpp.o querydb_build_dir/utils.cpp.o querydb_build_dir/version.cpp.o 
function_includedir=-I../../src_base/function/.
logger_obj=querydb_build_dir/CFilelogService.cpp.o querydb_build_dir/CLogger.cpp.o querydb_build_dir/CProbeLogger.cpp.o querydb_build_dir/CSyslogService.cpp.o querydb_build_dir/monitorIndex.cpp.o 
logger_includedir=-I../../src_base/logger/.
netstruct_obj=querydb_build_dir/errorDefine.cpp.o querydb_build_dir/TableDefine.cpp.o 
netstruct_includedir=-I../../src_base/netstruct/.
field_obj=querydb_build_dir/FieldData.cpp.o querydb_build_dir/FieldMap.cpp.o 
field_includedir=-I../../src_base/field/.
ofserviceapi_include_includedir=-I../../libs/ofserviceapi/1.0/include/.
ofapibase_obj=querydb_build_dir/OutFogServiceApiWrapper.cpp.o 
ofapibase_includedir=-I../../libs/ofserviceapi/ofapibase/.
sqlapi_include_includedir=-I../../libs/sqlapi/4.1.3/include/.
sqlapi_lib_lib=-L../../libs/sqlapi/4.1.3/./linux_x64 -lmysqlclient_r -lsqlapi ../../libs/sqlapi/4.1.3/./linux_x64/libmysqlclient.so.18 
sqlapi_lib_includedir= 
dbconnect_obj=querydb_build_dir/DbConnection.cpp.o querydb_build_dir/DbHelper.cpp.o 
dbconnect_includedir=-I../../libs/sqlapi/dbconnect/.
querydb_obj=querydb_build_dir/AccountDetailHandler.cpp.o querydb_build_dir/App.cpp.o querydb_build_dir/FinishOrderHandler.cpp.o querydb_build_dir/FinishTriggerOrderHandler.cpp.o querydb_build_dir/KLineHandler.cpp.o querydb_build_dir/SettleDetailHandler.cpp.o querydb_build_dir/TradeHandler.cpp.o 
querydb_includedir=-I../../src/querydb/.

all_objs=$(crypt_obj) $(datastruct_obj) $(function_obj) $(logger_obj) $(netstruct_obj) $(field_obj) $(ofapibase_obj) $(dbconnect_obj) $(querydb_obj) 

all_libs=$(sqlapi_lib_lib) 
INCLUDEDIR= $(crypt_includedir)  $(datastruct_includedir)  $(function_includedir)  $(logger_includedir)  $(netstruct_includedir)  $(field_includedir)  $(ofserviceapi_include_includedir)  $(ofapibase_includedir)  $(sqlapi_include_includedir)  $(sqlapi_lib_includedir)  $(dbconnect_includedir)  $(querydb_includedir) 

querydb_build_dir/cryptUtility.cpp.o: ../../src_base/crypt/cryptUtility.cpp $(crypt_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/crypt/cryptUtility.cpp -oquerydb_build_dir/cryptUtility.cpp.o
querydb_build_dir/Des.cpp.o: ../../src_base/crypt/Des.cpp $(crypt_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/crypt/Des.cpp -oquerydb_build_dir/Des.cpp.o
querydb_build_dir/hexEncode.cpp.o: ../../src_base/crypt/hexEncode.cpp $(crypt_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/crypt/hexEncode.cpp -oquerydb_build_dir/hexEncode.cpp.o
