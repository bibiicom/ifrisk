	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/datastruct/FieldDescribe.cpp -oquerydb_build_dir/FieldDescribe.cpp.o
querydb_build_dir/BaseFunction.cpp.o: ../../src_base/function/BaseFunction.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/function/BaseFunction.cpp -oquerydb_build_dir/BaseFunction.cpp.o
querydb_build_dir/Config.cpp.o: ../../src_base/function/Config.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/function/Config.cpp -oquerydb_build_dir/Config.cpp.o
querydb_build_dir/platform.cpp.o: ../../src_base/function/platform.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/function/platform.cpp -oquerydb_build_dir/platform.cpp.o
querydb_build_dir/printinfo.cpp.o: ../../src_base/function/printinfo.cpp $(function_include)
