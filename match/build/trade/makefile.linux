	-$(DEL) $(serviceQuery_obj)
	-$(DEL) $(serviceLogin_obj)
	-$(DEL) $(serviceSettlement_obj)
	-$(DEL) $(serviceTrade_obj)
	-$(DEL) $(wedge_obj)
	-$(DEL) $(wedgeMatch_obj)
	-$(DEL) $(wedgeRisk_obj)
	-$(DEL) $(wedgeControl_obj)
	-$(DEL) $(trade_obj)

	-$(DEL) $(target)
