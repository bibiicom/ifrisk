
CPP=g++ -fpic -std=c++11
LINK=g++
LIB32=ar -ru
PREP=g++ -E -P
COPY=cp
DEL=rm
MAKE=make
ECHO=echo



	
	
ISLIB=N
DEFINES=-DLINUX -DGCC
target=././/trade

APPEND_CPPFLAGS=-g3 -gdwarf-2 -O0 -pthread -m64

PROFILE_CPPFLAGS=

WARNING_CPPFLAGS=-Wall -Wno-sign-compare

CPPFLAGS=   -DDEBUG_NOT_LOG $(APPEND_CPPFLAGS) $(PROFILE_CPPFLAGS) $(WARNING_CPPFLAGS) $(DEFINES)
LIBS= -lpthread -lrt  

DEBUG_LDFLAGS=-g -O0 -m64

MAP_LDFLAGS=

PROFILE_LDFLAGS=

WARNING_LDFLAGS=-Wall -Wno-sign-compare

LDFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS) $(WARNING_LDFLAGS)
LIBARFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)
DLLARFLAGS=    -shared -Wl,-Bsymbolic -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)

all: code

code: clearoutput $(target)

clearoutput:
	@$(ECHO) Compiling...
	-mkdir -p trade_build_dir
	-mkdir -p ././/
	
function_obj=trade_build_dir/BaseFunction.cpp.o trade_build_dir/Config.cpp.o trade_build_dir/platform.cpp.o trade_build_dir/printinfo.cpp.o trade_build_dir/profile.cpp.o trade_build_dir/utility.cpp.o trade_build_dir/utils.cpp.o trade_build_dir/version.cpp.o 
function_includedir=-I../../src_base/function/.
logger_obj=trade_build_dir/CFilelogService.cpp.o trade_build_dir/CLogger.cpp.o trade_build_dir/CProbeLogger.cpp.o trade_build_dir/CSyslogService.cpp.o trade_build_dir/monitorIndex.cpp.o 
logger_includedir=-I../../src_base/logger/.
crypt_obj=trade_build_dir/cryptUtility.cpp.o trade_build_dir/Des.cpp.o trade_build_dir/hexEncode.cpp.o trade_build_dir/md5Handler.cpp.o 
crypt_includedir=-I../../src_base/crypt/.
datastruct_obj=trade_build_dir/BigDigit.cpp.o trade_build_dir/CDate.cpp.o trade_build_dir/CErrorEngine.cpp.o trade_build_dir/CSequence.cpp.o trade_build_dir/CSVParser.cpp.o trade_build_dir/CSVToField.cpp.o trade_build_dir/FieldDescribe.cpp.o 
datastruct_includedir=-I../../src_base/datastruct/.
netstruct_obj=trade_build_dir/errorDefine.cpp.o trade_build_dir/TableDefine.cpp.o 
netstruct_includedir=-I../../src_base/netstruct/.
field_obj=trade_build_dir/FieldData.cpp.o trade_build_dir/FieldMap.cpp.o 
field_includedir=-I../../src_base/field/.
mdbbase_obj=trade_build_dir/mdb.cpp.o trade_build_dir/mdbAction.cpp.o trade_build_dir/mdbIter.cpp.o trade_build_dir/mdbLog.cpp.o trade_build_dir/mdbSearch.cpp.o trade_build_dir/mdbStruct.cpp.o trade_build_dir/mdbTable.cpp.o 
mdbbase_includedir=-I../../src_base/mdb/mdbbase/.
mdbstruct_obj=trade_build_dir/Allocator.cpp.o trade_build_dir/CAVLTree.cpp.o trade_build_dir/CBaseObject.cpp.o trade_build_dir/CDatabaseDataFactory.cpp.o trade_build_dir/CDatabaseResource.cpp.o trade_build_dir/CDoubleHash.cpp.o trade_build_dir/CFixMem.cpp.o trade_build_dir/CHashIndex.cpp.o trade_build_dir/CTransaction.cpp.o 
mdbstruct_includedir=-I../../src_base/mdb/mdbstruct/.
mdbchange_obj=trade_build_dir/AlterService.cpp.o trade_build_dir/AlterServiceInterface.cpp.o trade_build_dir/TableTrigger.cpp.o 
mdbchange_includedir=-I../../src_base/mdb/mdbchange/.
ofserviceapi_include_includedir=-I../../libs/ofserviceapi/1.0/include/.
ofapibase_obj=trade_build_dir/OutFogServiceApiWrapper.cpp.o 
ofapibase_includedir=-I../../libs/ofserviceapi/ofapibase/.
service_obj=trade_build_dir/ServiceShare.cpp.o trade_build_dir/tradingTools.cpp.o 
service_includedir=-I../../src/service/.
serviceQuery_obj=trade_build_dir/QueryServiceInterface.cpp.o 
serviceQuery_includedir=-I../../src/service/serviceQuery/.
serviceLogin_obj=trade_build_dir/LoginService.cpp.o trade_build_dir/LoginServiceInterface.cpp.o 
serviceLogin_includedir=-I../../src/service/serviceLogin/.
serviceSettlement_obj=trade_build_dir/CSettlementService.cpp.o trade_build_dir/SettlementServiceInterface.cpp.o 
serviceSettlement_includedir=-I../../src/service/serviceSettlement/.
serviceTrade_obj=trade_build_dir/CPositionChangeList.cpp.o trade_build_dir/CTradeService.cpp.o trade_build_dir/TradeServiceInterface.cpp.o 
serviceTrade_includedir=-I../../src/service/serviceTrade/.
wedge_obj=trade_build_dir/CWedge.cpp.o trade_build_dir/CWedgeConfig.cpp.o trade_build_dir/CWedgeGroup.cpp.o 
wedge_includedir=-I../../src/service/serviceTrade/wedge/.
wedgeMatch_obj=trade_build_dir/genTrade.cpp.o trade_build_dir/KlineTriggers.cpp.o trade_build_dir/marketDataWedges.cpp.o trade_build_dir/matchWedges.cpp.o trade_build_dir/OrderBook.cpp.o trade_build_dir/TriggerOrderWedges.cpp.o 
wedgeMatch_includedir=-I../../src/service/serviceTrade/wedge/wedgeMatch/.
wedgeRisk_obj=trade_build_dir/accountAlgorithms.cpp.o trade_build_dir/accountWedges.cpp.o trade_build_dir/positionControlers.cpp.o trade_build_dir/positionLimitWedges.cpp.o 
wedgeRisk_includedir=-I../../src/service/serviceTrade/wedge/wedgeRisk/.
wedgeControl_obj=trade_build_dir/baseWedges.cpp.o trade_build_dir/orderTypeWedges.cpp.o trade_build_dir/priceControlWedges.cpp.o 
wedgeControl_includedir=-I../../src/service/serviceTrade/wedge/wedgeControl/.
trade_obj=trade_build_dir/BaseEngine.cpp.o trade_build_dir/Engine.cpp.o trade_build_dir/Exchange.cpp.o trade_build_dir/MyAlterService.cpp.o trade_build_dir/MyAlterServiceInterface.cpp.o trade_build_dir/TradeEngine.cpp.o 
trade_includedir=-I../../src/trade/.

all_objs=$(function_obj) $(logger_obj) $(crypt_obj) $(datastruct_obj) $(netstruct_obj) $(field_obj) $(mdbbase_obj) $(mdbstruct_obj) $(mdbchange_obj) $(ofapibase_obj) $(service_obj) $(serviceQuery_obj) $(serviceLogin_obj) $(serviceSettlement_obj) $(serviceTrade_obj) $(wedge_obj) $(wedgeMatch_obj) $(wedgeRisk_obj) $(wedgeControl_obj) $(trade_obj) 

all_libs=
INCLUDEDIR= $(function_includedir)  $(logger_includedir)  $(crypt_includedir)  $(datastruct_includedir)  $(netstruct_includedir)  $(field_includedir)  $(mdbbase_includedir)  $(mdbstruct_includedir)  $(mdbchange_includedir)  $(ofserviceapi_include_includedir)  $(ofapibase_includedir)  $(service_includedir)  $(serviceQuery_includedir)  $(serviceLogin_includedir)  $(serviceSettlement_includedir)  $(serviceTrade_includedir)  $(wedge_includedir)  $(wedgeMatch_includedir)  $(wedgeRisk_includedir)  $(wedgeControl_includedir)  $(trade_includedir) 

