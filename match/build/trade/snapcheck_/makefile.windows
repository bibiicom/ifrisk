
CPP=cl
LINK=link
LIB32=lib 
PREP=cl -nologo -EP
COPY=copy /y
DEL=del
MAKE=nmake
ECHO=echo



	
	
ISLIB=N
DEFINES=-DWINDOWS -DMSVC
target=.\..\\snapcheck.exe

APPEND_CPPFLAGS=-nologo -EHsc -MTd -Od -Gm -Zi -FD -Zm200

PROFILE_CPPFLAGS=

WARNING_CPPFLAGS=-W3

CPPFLAGS=   -DDEBUG_NOT_LOG $(APPEND_CPPFLAGS) $(PROFILE_CPPFLAGS) $(WARNING_CPPFLAGS) $(DEFINES)
LIBS= kernel32.lib user32.lib gdi32.lib winspool.lib comdlg32.lib advapi32.lib shell32.lib ole32.lib oleaut32.lib uuid.lib odbc32.lib odbccp32.lib ws2_32.lib  

DEBUG_LDFLAGS=/DEBUG

MAP_LDFLAGS=

PROFILE_LDFLAGS=

WARNING_LDFLAGS=/WARN:2

LDFLAGS=    -nologo /FIXED:NO $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS) $(WARNING_LDFLAGS)
LIBARFLAGS=    -nologo $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)
DLLARFLAGS=    -nologo /dll $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)

all: code

code: clearoutput $(target)

clearoutput:
	@$(ECHO) Compiling...
	-mkdir  snapcheck_build_dir
	-mkdir  .\..\\
	
datastruct_obj=snapcheck_build_dir\BigDigit.cpp.obj snapcheck_build_dir\CDate.cpp.obj snapcheck_build_dir\CErrorEngine.cpp.obj snapcheck_build_dir\CSequence.cpp.obj snapcheck_build_dir\CSVParser.cpp.obj snapcheck_build_dir\CSVToField.cpp.obj snapcheck_build_dir\FieldDescribe.cpp.obj 
datastruct_includedir=-I..\..\..\src_base\datastruct\.
function_obj=snapcheck_build_dir\BaseFunction.cpp.obj snapcheck_build_dir\Config.cpp.obj snapcheck_build_dir\platform.cpp.obj snapcheck_build_dir\printinfo.cpp.obj snapcheck_build_dir\profile.cpp.obj snapcheck_build_dir\utility.cpp.obj snapcheck_build_dir\utils.cpp.obj snapcheck_build_dir\version.cpp.obj 
function_includedir=-I..\..\..\src_base\function\.
logger_obj=snapcheck_build_dir\CFilelogService.cpp.obj snapcheck_build_dir\CLogger.cpp.obj snapcheck_build_dir\CProbeLogger.cpp.obj snapcheck_build_dir\CSyslogService.cpp.obj snapcheck_build_dir\monitorIndex.cpp.obj 
logger_includedir=-I..\..\..\src_base\logger\.
crypt_obj=snapcheck_build_dir\cryptUtility.cpp.obj snapcheck_build_dir\Des.cpp.obj snapcheck_build_dir\hexEncode.cpp.obj snapcheck_build_dir\md5Handler.cpp.obj 
crypt_includedir=-I..\..\..\src_base\crypt\.
mdbbase_obj=snapcheck_build_dir\mdb.cpp.obj snapcheck_build_dir\mdbAction.cpp.obj snapcheck_build_dir\mdbIter.cpp.obj snapcheck_build_dir\mdbLog.cpp.obj snapcheck_build_dir\mdbSearch.cpp.obj snapcheck_build_dir\mdbStruct.cpp.obj snapcheck_build_dir\mdbTable.cpp.obj 
mdbbase_includedir=-I..\..\..\src_base\mdb\mdbbase\.
mdbstruct_obj=snapcheck_build_dir\Allocator.cpp.obj snapcheck_build_dir\CAVLTree.cpp.obj snapcheck_build_dir\CBaseObject.cpp.obj snapcheck_build_dir\CDatabaseDataFactory.cpp.obj snapcheck_build_dir\CDatabaseResource.cpp.obj snapcheck_build_dir\CDoubleHash.cpp.obj snapcheck_build_dir\CFixMem.cpp.obj snapcheck_build_dir\CHashIndex.cpp.obj snapcheck_build_dir\CTransaction.cpp.obj 
mdbstruct_includedir=-I..\..\..\src_base\mdb\mdbstruct\.
mdbchange_obj=snapcheck_build_dir\AlterService.cpp.obj snapcheck_build_dir\AlterServiceInterface.cpp.obj snapcheck_build_dir\TableTrigger.cpp.obj 
mdbchange_includedir=-I..\..\..\src_base\mdb\mdbchange\.
netstruct_obj=snapcheck_build_dir\errorDefine.cpp.obj snapcheck_build_dir\TableDefine.cpp.obj 
netstruct_includedir=-I..\..\..\src_base\netstruct\.
field_obj=snapcheck_build_dir\FieldData.cpp.obj snapcheck_build_dir\FieldMap.cpp.obj 
field_includedir=-I..\..\..\src_base\field\.
ofserviceapi_include_includedir=-I..\..\..\libs\ofserviceapi\1.0\include\.
ofapibase_obj=snapcheck_build_dir\OutFogServiceApiWrapper.cpp.obj 
ofapibase_includedir=-I..\..\..\libs\ofserviceapi\ofapibase\.
service_obj=snapcheck_build_dir\ServiceShare.cpp.obj snapcheck_build_dir\tradingTools.cpp.obj 
service_includedir=-I..\..\..\src\service\.
snapcheck_obj=snapcheck_build_dir\BaseEngine.cpp.obj snapcheck_build_dir\Engine.cpp.obj snapcheck_build_dir\SnapCheck.cpp.obj snapcheck_build_dir\SnapCheckEngine.cpp.obj 
snapcheck_includedir=-I..\..\..\src\snapcheck\.

all_objs=$(datastruct_obj) $(function_obj) $(logger_obj) $(crypt_obj) $(mdbbase_obj) $(mdbstruct_obj) $(mdbchange_obj) $(netstruct_obj) $(field_obj) $(ofapibase_obj) $(service_obj) $(snapcheck_obj) 

all_libs=
INCLUDEDIR= $(datastruct_includedir)  $(function_includedir)  $(logger_includedir)  $(crypt_includedir)  $(mdbbase_includedir)  $(mdbstruct_includedir)  $(mdbchange_includedir)  $(netstruct_includedir)  $(field_includedir)  $(ofserviceapi_include_includedir)  $(ofapibase_includedir)  $(service_includedir)  $(snapcheck_includedir) 

snapcheck_build_dir\BigDigit.cpp.obj: ..\..\..\src_base\datastruct\BigDigit.cpp $(datastruct_include)
