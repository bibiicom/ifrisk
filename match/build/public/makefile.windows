
CPP=cl
LINK=link
LIB32=lib 
PREP=cl -nologo -EP
COPY=copy /y
DEL=del
MAKE=nmake
ECHO=echo



	
	
ISLIB=N
DEFINES=-DWINDOWS -DMSVC
target=.\.\\public.exe

APPEND_CPPFLAGS=-nologo -EHsc -MTd -Od -Gm -Zi -FD -Zm200

PROFILE_CPPFLAGS=

WARNING_CPPFLAGS=-W3

CPPFLAGS=   -DDEBUG_NOT_LOG $(APPEND_CPPFLAGS) $(PROFILE_CPPFLAGS) $(WARNING_CPPFLAGS) $(DEFINES)
LIBS= kernel32.lib user32.lib gdi32.lib winspool.lib comdlg32.lib advapi32.lib shell32.lib ole32.lib oleaut32.lib uuid.lib odbc32.lib odbccp32.lib ws2_32.lib  

DEBUG_LDFLAGS=/DEBUG

MAP_LDFLAGS=

PROFILE_LDFLAGS=

WARNING_LDFLAGS=/WARN:2

LDFLAGS=    -nologo /FIXED:NO $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS) $(WARNING_LDFLAGS)
LIBARFLAGS=    -nologo $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)
DLLARFLAGS=    -nologo /dll $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)

all: code

code: clearoutput $(target)

clearoutput:
	@$(ECHO) Compiling...
	-mkdir  public_build_dir
	-mkdir  .\.\\
	
crypt_obj=public_build_dir\cryptUtility.cpp.obj public_build_dir\Des.cpp.obj public_build_dir\hexEncode.cpp.obj public_build_dir\md5Handler.cpp.obj 
crypt_includedir=-I..\..\src_base\crypt\.
datastruct_obj=public_build_dir\BigDigit.cpp.obj public_build_dir\CDate.cpp.obj public_build_dir\CErrorEngine.cpp.obj public_build_dir\CSequence.cpp.obj public_build_dir\CSVParser.cpp.obj public_build_dir\CSVToField.cpp.obj public_build_dir\FieldDescribe.cpp.obj 
datastruct_includedir=-I..\..\src_base\datastruct\.
function_obj=public_build_dir\BaseFunction.cpp.obj public_build_dir\Config.cpp.obj public_build_dir\platform.cpp.obj public_build_dir\printinfo.cpp.obj public_build_dir\profile.cpp.obj public_build_dir\utility.cpp.obj public_build_dir\utils.cpp.obj public_build_dir\version.cpp.obj 
function_includedir=-I..\..\src_base\function\.
logger_obj=public_build_dir\CFilelogService.cpp.obj public_build_dir\CLogger.cpp.obj public_build_dir\CProbeLogger.cpp.obj public_build_dir\CSyslogService.cpp.obj public_build_dir\monitorIndex.cpp.obj 
logger_includedir=-I..\..\src_base\logger\.
netstruct_obj=public_build_dir\errorDefine.cpp.obj public_build_dir\TableDefine.cpp.obj 
netstruct_includedir=-I..\..\src_base\netstruct\.
field_obj=public_build_dir\FieldData.cpp.obj public_build_dir\FieldMap.cpp.obj 
field_includedir=-I..\..\src_base\field\.
mdbbase_obj=public_build_dir\mdb.cpp.obj public_build_dir\mdbAction.cpp.obj public_build_dir\mdbIter.cpp.obj public_build_dir\mdbLog.cpp.obj public_build_dir\mdbSearch.cpp.obj public_build_dir\mdbStruct.cpp.obj public_build_dir\mdbTable.cpp.obj 
mdbbase_includedir=-I..\..\src_base\mdb\mdbbase\.
mdbstruct_obj=public_build_dir\Allocator.cpp.obj public_build_dir\CAVLTree.cpp.obj public_build_dir\CBaseObject.cpp.obj public_build_dir\CDatabaseDataFactory.cpp.obj public_build_dir\CDatabaseResource.cpp.obj public_build_dir\CDoubleHash.cpp.obj public_build_dir\CFixMem.cpp.obj public_build_dir\CHashIndex.cpp.obj public_build_dir\CTransaction.cpp.obj 
mdbstruct_includedir=-I..\..\src_base\mdb\mdbstruct\.
ofserviceapi_include_includedir=-I..\..\libs\ofserviceapi\1.0\include\.
ofapibase_obj=public_build_dir\OutFogServiceApiWrapper.cpp.obj 
ofapibase_includedir=-I..\..\libs\ofserviceapi\ofapibase\.
sqlapi_include_includedir=-I..\..\libs\sqlapi\4.1.3\include\.
sqlapi_lib_lib=/libpath:..\..\libs\sqlapi\4.1.3\.\windows_x64 sqlapi.lib 
sqlapi_lib_includedir= 
dbconnect_obj=public_build_dir\DbConnection.cpp.obj public_build_dir\DbHelper.cpp.obj 
dbconnect_includedir=-I..\..\libs\sqlapi\dbconnect\.
modMarketData_obj=public_build_dir\CServiceTimer.cpp.obj public_build_dir\MarketDataService.cpp.obj public_build_dir\MarketDataTimer.cpp.obj public_build_dir\MarketDataTriggers.cpp.obj 
modMarketData_includedir=-I..\..\src\modMarketData\.
serviceLogin_obj=public_build_dir\LoginService.cpp.obj public_build_dir\LoginServiceInterface.cpp.obj 
serviceLogin_includedir=-I..\..\src\service\serviceLogin\.
service_obj=public_build_dir\ServiceShare.cpp.obj public_build_dir\tradingTools.cpp.obj 
service_includedir=-I..\..\src\service\.
public_obj=public_build_dir\App.cpp.obj 
public_includedir=-I..\..\src\public\.

all_objs=$(crypt_obj) $(datastruct_obj) $(function_obj) $(logger_obj) $(netstruct_obj) $(field_obj) $(mdbbase_obj) $(mdbstruct_obj) $(ofapibase_obj) $(dbconnect_obj) $(modMarketData_obj) $(serviceLogin_obj) $(service_obj) $(public_obj) 

all_libs=$(sqlapi_lib_lib) 
INCLUDEDIR= $(crypt_includedir)  $(datastruct_includedir)  $(function_includedir)  $(logger_includedir)  $(netstruct_includedir)  $(field_includedir)  $(mdbbase_includedir)  $(mdbstruct_includedir)  $(ofserviceapi_include_includedir)  $(ofapibase_includedir)  $(sqlapi_include_includedir)  $(sqlapi_lib_includedir)  $(dbconnect_includedir)  $(modMarketData_includedir)  $(serviceLogin_includedir)  $(service_includedir)  $(public_includedir) 

