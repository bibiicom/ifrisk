	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/thread/Thread.cpp -oOneMegaToEastMoneyKc50_build_dir/Thread.cpp.o
OneMegaToEastMoneyKc50_build_dir/ApiKeyUtil.cpp.o: ../../../libs/openssl/1.1.0h/include/ApiKeyUtil.cpp $(openssl_include_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../libs/openssl/1.1.0h/include/ApiKeyUtil.cpp -oOneMegaToEastMoneyKc50_build_dir/ApiKeyUtil.cpp.o
OneMegaToEastMoneyKc50_build_dir/Link.cpp.o: ./Link.cpp $(OneMegaToEastMoneyKc50_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ./Link.cpp -oOneMegaToEastMoneyKc50_build_dir/Link.cpp.o

$(target): $(all_objs)
	$(LINK) $(DLLARFLAGS) -o $@ $(all_objs) $(all_libs) $(LIBS)

clean:
	-$(DEL) $(datastruct_obj)
	-$(DEL) $(function_obj)
	-$(DEL) $(mongoose79_obj)
	-$(DEL) $(tool_obj)
	-$(DEL) $(jsoncpp_obj)
	-$(DEL) $(thread_obj)
	-$(DEL) $(openssl_include_obj)
	-$(DEL) $(OneMegaToEastMoneyKc50_obj)

	-$(DEL) $(target)
	-$(DEL) ././OneMegaToEastMoneyKc50.a
