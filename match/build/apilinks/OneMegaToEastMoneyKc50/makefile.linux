	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/mongoose79/HttpClient.cpp -oOneMegaToEastMoneyKc50_build_dir/HttpClient.cpp.o
OneMegaToEastMoneyKc50_build_dir/SMTPClient.cpp.o: ../../../src_base/mongoose79/SMTPClient.cpp $(mongoose79_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/mongoose79/SMTPClient.cpp -oOneMegaToEastMoneyKc50_build_dir/SMTPClient.cpp.o
OneMegaToEastMoneyKc50_build_dir/WSClient.cpp.o: ../../../src_base/mongoose79/WSClient.cpp $(mongoose79_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/mongoose79/WSClient.cpp -oOneMegaToEastMoneyKc50_build_dir/WSClient.cpp.o
OneMegaToEastMoneyKc50_build_dir/mongoose.c.o: ../../../src_base/mongoose79/mongoose.c $(mongoose79_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/mongoose79/mongoose.c -oOneMegaToEastMoneyKc50_build_dir/mongoose.c.o
OneMegaToEastMoneyKc50_build_dir/tool.cpp.o: ../../../src_base/tool/tool.cpp $(tool_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/tool/tool.cpp -oOneMegaToEastMoneyKc50_build_dir/tool.cpp.o
OneMegaToEastMoneyKc50_build_dir/json_reader.cpp.o: ../../../src_base/jsoncpp/json_reader.cpp $(jsoncpp_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/jsoncpp/json_reader.cpp -oOneMegaToEastMoneyKc50_build_dir/json_reader.cpp.o
OneMegaToEastMoneyKc50_build_dir/json_value.cpp.o: ../../../src_base/jsoncpp/json_value.cpp $(jsoncpp_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/jsoncpp/json_value.cpp -oOneMegaToEastMoneyKc50_build_dir/json_value.cpp.o
OneMegaToEastMoneyKc50_build_dir/json_writer.cpp.o: ../../../src_base/jsoncpp/json_writer.cpp $(jsoncpp_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/jsoncpp/json_writer.cpp -oOneMegaToEastMoneyKc50_build_dir/json_writer.cpp.o
OneMegaToEastMoneyKc50_build_dir/Semaphore.cpp.o: ../../../src_base/thread/Semaphore.cpp $(thread_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/thread/Semaphore.cpp -oOneMegaToEastMoneyKc50_build_dir/Semaphore.cpp.o
