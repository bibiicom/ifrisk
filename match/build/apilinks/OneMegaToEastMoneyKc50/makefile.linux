	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/datastruct/CSVToField.cpp -oOneMegaToEastMoneyKc50_build_dir/CSVToField.cpp.o
OneMegaToEastMoneyKc50_build_dir/FieldDescribe.cpp.o: ../../../src_base/datastruct/FieldDescribe.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/datastruct/FieldDescribe.cpp -oOneMegaToEastMoneyKc50_build_dir/FieldDescribe.cpp.o
OneMegaToEastMoneyKc50_build_dir/BaseFunction.cpp.o: ../../../src_base/function/BaseFunction.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/BaseFunction.cpp -oOneMegaToEastMoneyKc50_build_dir/BaseFunction.cpp.o
OneMegaToEastMoneyKc50_build_dir/Config.cpp.o: ../../../src_base/function/Config.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/Config.cpp -oOneMegaToEastMoneyKc50_build_dir/Config.cpp.o
OneMegaToEastMoneyKc50_build_dir/platform.cpp.o: ../../../src_base/function/platform.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/platform.cpp -oOneMegaToEastMoneyKc50_build_dir/platform.cpp.o
OneMegaToEastMoneyKc50_build_dir/printinfo.cpp.o: ../../../src_base/function/printinfo.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/printinfo.cpp -oOneMegaToEastMoneyKc50_build_dir/printinfo.cpp.o
OneMegaToEastMoneyKc50_build_dir/profile.cpp.o: ../../../src_base/function/profile.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/profile.cpp -oOneMegaToEastMoneyKc50_build_dir/profile.cpp.o
OneMegaToEastMoneyKc50_build_dir/utility.cpp.o: ../../../src_base/function/utility.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/utility.cpp -oOneMegaToEastMoneyKc50_build_dir/utility.cpp.o
OneMegaToEastMoneyKc50_build_dir/utils.cpp.o: ../../../src_base/function/utils.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/utils.cpp -oOneMegaToEastMoneyKc50_build_dir/utils.cpp.o
OneMegaToEastMoneyKc50_build_dir/version.cpp.o: ../../../src_base/function/version.cpp $(function_include)
