
CPP=g++ -fpic -std=c++11
LINK=g++
LIB32=ar -ru
PREP=g++ -E -P
COPY=cp
DEL=rm
MAKE=make
ECHO=echo



	
	
ISLIB=Y
DEFINES=-DLINUX -DGCC -DISLIB
target=././libOneMegaToEastMoneyKc50.so

APPEND_CPPFLAGS=-g3 -gdwarf-2 -O0 -pthread -m64

PROFILE_CPPFLAGS=

WARNING_CPPFLAGS=-Wall -Wno-sign-compare

CPPFLAGS=   -DDDEBUG_NOT_LOG -DONE_MEGAAPI_IS_LIB -DLIB_ONE_MEGA_API_EXPORT $(APPEND_CPPFLAGS) $(PROFILE_CPPFLAGS) $(WARNING_CPPFLAGS) $(DEFINES)
LIBS= -lpthread -lrt  

DEBUG_LDFLAGS=-g -O0 -m64

MAP_LDFLAGS=

PROFILE_LDFLAGS=

WARNING_LDFLAGS=-Wall -Wno-sign-compare

LDFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS) $(WARNING_LDFLAGS)
LIBARFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)
DLLARFLAGS=    -shared -Wl,-Bsymbolic -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)

all: code

code: clearoutput $(target)

clearoutput:
	@$(ECHO) Compiling...
	-mkdir -p OneMegaToEastMoneyKc50_build_dir
	-mkdir -p ././
	
datastruct_obj=OneMegaToEastMoneyKc50_build_dir/BigDigit.cpp.o OneMegaToEastMoneyKc50_build_dir/CDate.cpp.o OneMegaToEastMoneyKc50_build_dir/CErrorEngine.cpp.o OneMegaToEastMoneyKc50_build_dir/CSequence.cpp.o OneMegaToEastMoneyKc50_build_dir/CSVParser.cpp.o OneMegaToEastMoneyKc50_build_dir/CSVToField.cpp.o OneMegaToEastMoneyKc50_build_dir/FieldDescribe.cpp.o 
datastruct_includedir=-I../../../src_base/datastruct/.
function_obj=OneMegaToEastMoneyKc50_build_dir/BaseFunction.cpp.o OneMegaToEastMoneyKc50_build_dir/Config.cpp.o OneMegaToEastMoneyKc50_build_dir/platform.cpp.o OneMegaToEastMoneyKc50_build_dir/printinfo.cpp.o OneMegaToEastMoneyKc50_build_dir/profile.cpp.o OneMegaToEastMoneyKc50_build_dir/utility.cpp.o OneMegaToEastMoneyKc50_build_dir/utils.cpp.o OneMegaToEastMoneyKc50_build_dir/version.cpp.o 
function_includedir=-I../../../src_base/function/.
mongoose79_obj=OneMegaToEastMoneyKc50_build_dir/HttpClient.cpp.o OneMegaToEastMoneyKc50_build_dir/SMTPClient.cpp.o OneMegaToEastMoneyKc50_build_dir/WSClient.cpp.o OneMegaToEastMoneyKc50_build_dir/mongoose.c.o 
mongoose79_includedir=-I../../../src_base/mongoose79/.
tool_obj=OneMegaToEastMoneyKc50_build_dir/tool.cpp.o 
tool_includedir=-I../../../src_base/tool/.
jsoncpp_obj=OneMegaToEastMoneyKc50_build_dir/json_reader.cpp.o OneMegaToEastMoneyKc50_build_dir/json_value.cpp.o OneMegaToEastMoneyKc50_build_dir/json_writer.cpp.o 
jsoncpp_includedir=-I../../../src_base/jsoncpp/.
thread_obj=OneMegaToEastMoneyKc50_build_dir/Semaphore.cpp.o OneMegaToEastMoneyKc50_build_dir/Thread.cpp.o 
thread_includedir=-I../../../src_base/thread/.
include_includedir=-I../../../src_api/include/.
openssl_include_obj=OneMegaToEastMoneyKc50_build_dir/ApiKeyUtil.cpp.o 
openssl_include_includedir=-I../../../libs/openssl/1.1.0h/include/.
openssl_lib_lib=-L../../../libs/openssl/1.1.0h/static/linux_x64 -lassl -lcrypto 
openssl_lib_includedir= 
OneMegaToEastMoneyKc50_obj=OneMegaToEastMoneyKc50_build_dir/Link.cpp.o 
OneMegaToEastMoneyKc50_includedir=-I./.

all_objs=$(datastruct_obj) $(function_obj) $(mongoose79_obj) $(tool_obj) $(jsoncpp_obj) $(thread_obj) $(openssl_include_obj) $(OneMegaToEastMoneyKc50_obj) 

all_libs=$(openssl_lib_lib) 
INCLUDEDIR= $(datastruct_includedir)  $(function_includedir)  $(mongoose79_includedir)  $(tool_includedir)  $(jsoncpp_includedir)  $(thread_includedir)  $(include_includedir)  $(openssl_include_includedir)  $(openssl_lib_includedir)  $(OneMegaToEastMoneyKc50_includedir) 

OneMegaToEastMoneyKc50_build_dir/BigDigit.cpp.o: ../../../src_base/datastruct/BigDigit.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/datastruct/BigDigit.cpp -oOneMegaToEastMoneyKc50_build_dir/BigDigit.cpp.o
OneMegaToEastMoneyKc50_build_dir/CDate.cpp.o: ../../../src_base/datastruct/CDate.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/datastruct/CDate.cpp -oOneMegaToEastMoneyKc50_build_dir/CDate.cpp.o
OneMegaToEastMoneyKc50_build_dir/CErrorEngine.cpp.o: ../../../src_base/datastruct/CErrorEngine.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/datastruct/CErrorEngine.cpp -oOneMegaToEastMoneyKc50_build_dir/CErrorEngine.cpp.o
