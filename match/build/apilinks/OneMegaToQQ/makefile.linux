
CPP=g++ -fpic -std=c++11
LINK=g++
LIB32=ar -ru
PREP=g++ -E -P
COPY=cp
DEL=rm
MAKE=make
ECHO=echo



	
	
ISLIB=Y
DEFINES=-DLINUX -DGCC -DISLIB
target=././libOneMegaToQQ.so

APPEND_CPPFLAGS=-g3 -gdwarf-2 -O0 -pthread -m64

PROFILE_CPPFLAGS=

WARNING_CPPFLAGS=-Wall -Wno-sign-compare

CPPFLAGS=   -DDDEBUG_NOT_LOG -DONE_MEGAAPI_IS_LIB -DLIB_ONE_MEGA_API_EXPORT -DMG_ENABLE_OPENSSL=0 $(APPEND_CPPFLAGS) $(PROFILE_CPPFLAGS) $(WARNING_CPPFLAGS) $(DEFINES)
LIBS= -lpthread -lrt  

DEBUG_LDFLAGS=-g -O0 -m64

MAP_LDFLAGS=

PROFILE_LDFLAGS=

WARNING_LDFLAGS=-Wall -Wno-sign-compare

LDFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS) $(WARNING_LDFLAGS)
LIBARFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)
DLLARFLAGS=    -shared -Wl,-Bsymbolic -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)

all: code

code: clearoutput $(target)

clearoutput:
	@$(ECHO) Compiling...
	-mkdir -p OneMegaToQQ_build_dir
	-mkdir -p ././
	
datastruct_obj=OneMegaToQQ_build_dir/BigDigit.cpp.o OneMegaToQQ_build_dir/CDate.cpp.o OneMegaToQQ_build_dir/CErrorEngine.cpp.o OneMegaToQQ_build_dir/CSequence.cpp.o OneMegaToQQ_build_dir/CSVParser.cpp.o OneMegaToQQ_build_dir/CSVToField.cpp.o OneMegaToQQ_build_dir/FieldDescribe.cpp.o 
datastruct_includedir=-I../../../src_base/datastruct/.
function_obj=OneMegaToQQ_build_dir/BaseFunction.cpp.o OneMegaToQQ_build_dir/Config.cpp.o OneMegaToQQ_build_dir/platform.cpp.o OneMegaToQQ_build_dir/printinfo.cpp.o OneMegaToQQ_build_dir/profile.cpp.o OneMegaToQQ_build_dir/utility.cpp.o OneMegaToQQ_build_dir/utils.cpp.o OneMegaToQQ_build_dir/version.cpp.o 
function_includedir=-I../../../src_base/function/.
mongoose79_obj=OneMegaToQQ_build_dir/HttpClient.cpp.o OneMegaToQQ_build_dir/SMTPClient.cpp.o OneMegaToQQ_build_dir/WSClient.cpp.o OneMegaToQQ_build_dir/mongoose.c.o 
mongoose79_includedir=-I../../../src_base/mongoose79/.
tool_obj=OneMegaToQQ_build_dir/tool.cpp.o 
tool_includedir=-I../../../src_base/tool/.
jsoncpp_obj=OneMegaToQQ_build_dir/json_reader.cpp.o OneMegaToQQ_build_dir/json_value.cpp.o OneMegaToQQ_build_dir/json_writer.cpp.o 
jsoncpp_includedir=-I../../../src_base/jsoncpp/.
thread_obj=OneMegaToQQ_build_dir/Semaphore.cpp.o OneMegaToQQ_build_dir/Thread.cpp.o 
thread_includedir=-I../../../src_base/thread/.
include_includedir=-I../../../src_api/include/.
OneMegaToQQ_obj=OneMegaToQQ_build_dir/Link.cpp.o 
OneMegaToQQ_includedir=-I./.

all_objs=$(datastruct_obj) $(function_obj) $(mongoose79_obj) $(tool_obj) $(jsoncpp_obj) $(thread_obj) $(OneMegaToQQ_obj) 

all_libs=
INCLUDEDIR= $(datastruct_includedir)  $(function_includedir)  $(mongoose79_includedir)  $(tool_includedir)  $(jsoncpp_includedir)  $(thread_includedir)  $(include_includedir)  $(OneMegaToQQ_includedir) 

OneMegaToQQ_build_dir/BigDigit.cpp.o: ../../../src_base/datastruct/BigDigit.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/datastruct/BigDigit.cpp -oOneMegaToQQ_build_dir/BigDigit.cpp.o
OneMegaToQQ_build_dir/CDate.cpp.o: ../../../src_base/datastruct/CDate.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/datastruct/CDate.cpp -oOneMegaToQQ_build_dir/CDate.cpp.o
OneMegaToQQ_build_dir/CErrorEngine.cpp.o: ../../../src_base/datastruct/CErrorEngine.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/datastruct/CErrorEngine.cpp -oOneMegaToQQ_build_dir/CErrorEngine.cpp.o
OneMegaToQQ_build_dir/CSequence.cpp.o: ../../../src_base/datastruct/CSequence.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/datastruct/CSequence.cpp -oOneMegaToQQ_build_dir/CSequence.cpp.o
OneMegaToQQ_build_dir/CSVParser.cpp.o: ../../../src_base/datastruct/CSVParser.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/datastruct/CSVParser.cpp -oOneMegaToQQ_build_dir/CSVParser.cpp.o
OneMegaToQQ_build_dir/CSVToField.cpp.o: ../../../src_base/datastruct/CSVToField.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/datastruct/CSVToField.cpp -oOneMegaToQQ_build_dir/CSVToField.cpp.o
OneMegaToQQ_build_dir/FieldDescribe.cpp.o: ../../../src_base/datastruct/FieldDescribe.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/datastruct/FieldDescribe.cpp -oOneMegaToQQ_build_dir/FieldDescribe.cpp.o
OneMegaToQQ_build_dir/BaseFunction.cpp.o: ../../../src_base/function/BaseFunction.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/BaseFunction.cpp -oOneMegaToQQ_build_dir/BaseFunction.cpp.o
OneMegaToQQ_build_dir/Config.cpp.o: ../../../src_base/function/Config.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/Config.cpp -oOneMegaToQQ_build_dir/Config.cpp.o
OneMegaToQQ_build_dir/platform.cpp.o: ../../../src_base/function/platform.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/platform.cpp -oOneMegaToQQ_build_dir/platform.cpp.o
OneMegaToQQ_build_dir/printinfo.cpp.o: ../../../src_base/function/printinfo.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/printinfo.cpp -oOneMegaToQQ_build_dir/printinfo.cpp.o
OneMegaToQQ_build_dir/profile.cpp.o: ../../../src_base/function/profile.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/profile.cpp -oOneMegaToQQ_build_dir/profile.cpp.o
OneMegaToQQ_build_dir/utility.cpp.o: ../../../src_base/function/utility.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/utility.cpp -oOneMegaToQQ_build_dir/utility.cpp.o
OneMegaToQQ_build_dir/utils.cpp.o: ../../../src_base/function/utils.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/utils.cpp -oOneMegaToQQ_build_dir/utils.cpp.o
OneMegaToQQ_build_dir/version.cpp.o: ../../../src_base/function/version.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/function/version.cpp -oOneMegaToQQ_build_dir/version.cpp.o
OneMegaToQQ_build_dir/HttpClient.cpp.o: ../../../src_base/mongoose79/HttpClient.cpp $(mongoose79_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/mongoose79/HttpClient.cpp -oOneMegaToQQ_build_dir/HttpClient.cpp.o
OneMegaToQQ_build_dir/SMTPClient.cpp.o: ../../../src_base/mongoose79/SMTPClient.cpp $(mongoose79_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/mongoose79/SMTPClient.cpp -oOneMegaToQQ_build_dir/SMTPClient.cpp.o
OneMegaToQQ_build_dir/WSClient.cpp.o: ../../../src_base/mongoose79/WSClient.cpp $(mongoose79_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/mongoose79/WSClient.cpp -oOneMegaToQQ_build_dir/WSClient.cpp.o
OneMegaToQQ_build_dir/mongoose.c.o: ../../../src_base/mongoose79/mongoose.c $(mongoose79_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/mongoose79/mongoose.c -oOneMegaToQQ_build_dir/mongoose.c.o
OneMegaToQQ_build_dir/tool.cpp.o: ../../../src_base/tool/tool.cpp $(tool_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/tool/tool.cpp -oOneMegaToQQ_build_dir/tool.cpp.o
OneMegaToQQ_build_dir/json_reader.cpp.o: ../../../src_base/jsoncpp/json_reader.cpp $(jsoncpp_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/jsoncpp/json_reader.cpp -oOneMegaToQQ_build_dir/json_reader.cpp.o
OneMegaToQQ_build_dir/json_value.cpp.o: ../../../src_base/jsoncpp/json_value.cpp $(jsoncpp_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/jsoncpp/json_value.cpp -oOneMegaToQQ_build_dir/json_value.cpp.o
OneMegaToQQ_build_dir/json_writer.cpp.o: ../../../src_base/jsoncpp/json_writer.cpp $(jsoncpp_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/jsoncpp/json_writer.cpp -oOneMegaToQQ_build_dir/json_writer.cpp.o
OneMegaToQQ_build_dir/Semaphore.cpp.o: ../../../src_base/thread/Semaphore.cpp $(thread_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/thread/Semaphore.cpp -oOneMegaToQQ_build_dir/Semaphore.cpp.o
OneMegaToQQ_build_dir/Thread.cpp.o: ../../../src_base/thread/Thread.cpp $(thread_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../../src_base/thread/Thread.cpp -oOneMegaToQQ_build_dir/Thread.cpp.o
OneMegaToQQ_build_dir/Link.cpp.o: ./Link.cpp $(OneMegaToQQ_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ./Link.cpp -oOneMegaToQQ_build_dir/Link.cpp.o

$(target): $(all_objs)
	$(LINK) $(DLLARFLAGS) -o $@ $(all_objs) $(all_libs) $(LIBS)

clean:
	-$(DEL) $(datastruct_obj)
	-$(DEL) $(function_obj)
	-$(DEL) $(mongoose79_obj)
	-$(DEL) $(tool_obj)
	-$(DEL) $(jsoncpp_obj)
	-$(DEL) $(thread_obj)
	-$(DEL) $(OneMegaToQQ_obj)

	-$(DEL) $(target)
	-$(DEL) ././OneMegaToQQ.a
