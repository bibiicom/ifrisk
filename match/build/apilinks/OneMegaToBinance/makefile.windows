
CPP=cl
LINK=link
LIB32=lib 
PREP=cl -nologo -EP
COPY=copy /y
DEL=del
MAKE=nmake
ECHO=echo



	
	
ISLIB=Y
DEFINES=-DWINDOWS -DMSVC -DISLIB
target=.\.\OneMegaToBinance.dll

APPEND_CPPFLAGS=-nologo -EHsc -MTd -Od -Gm -Zi -FD -Zm200

PROFILE_CPPFLAGS=

WARNING_CPPFLAGS=-W3

CPPFLAGS=   -DDDEBUG_NOT_LOG -DONE_MEGAAPI_IS_LIB -DLIB_ONE_MEGA_API_EXPORT $(APPEND_CPPFLAGS) $(PROFILE_CPPFLAGS) $(WARNING_CPPFLAGS) $(DEFINES)
LIBS= kernel32.lib user32.lib gdi32.lib winspool.lib comdlg32.lib advapi32.lib shell32.lib ole32.lib oleaut32.lib uuid.lib odbc32.lib odbccp32.lib ws2_32.lib  

DEBUG_LDFLAGS=/DEBUG

MAP_LDFLAGS=

PROFILE_LDFLAGS=

WARNING_LDFLAGS=/WARN:2

LDFLAGS=    -nologo /FIXED:NO $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS) $(WARNING_LDFLAGS)
LIBARFLAGS=    -nologo $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)
DLLARFLAGS=    -nologo /dll $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)

all: code

code: clearoutput $(target)

clearoutput:
	@$(ECHO) Compiling...
	-mkdir  OneMegaToBinance_build_dir
	-mkdir  .\.\
	
datastruct_obj=OneMegaToBinance_build_dir\BigDigit.cpp.obj OneMegaToBinance_build_dir\CDate.cpp.obj OneMegaToBinance_build_dir\CErrorEngine.cpp.obj OneMegaToBinance_build_dir\CSequence.cpp.obj OneMegaToBinance_build_dir\CSVParser.cpp.obj OneMegaToBinance_build_dir\CSVToField.cpp.obj OneMegaToBinance_build_dir\FieldDescribe.cpp.obj 
datastruct_includedir=-I..\..\..\src_base\datastruct\.
function_obj=OneMegaToBinance_build_dir\BaseFunction.cpp.obj OneMegaToBinance_build_dir\Config.cpp.obj OneMegaToBinance_build_dir\platform.cpp.obj OneMegaToBinance_build_dir\printinfo.cpp.obj OneMegaToBinance_build_dir\profile.cpp.obj OneMegaToBinance_build_dir\utility.cpp.obj OneMegaToBinance_build_dir\utils.cpp.obj OneMegaToBinance_build_dir\version.cpp.obj 
function_includedir=-I..\..\..\src_base\function\.
mongoose79_obj=OneMegaToBinance_build_dir\HttpClient.cpp.obj OneMegaToBinance_build_dir\SMTPClient.cpp.obj OneMegaToBinance_build_dir\WSClient.cpp.obj OneMegaToBinance_build_dir\mongoose.c.obj 
mongoose79_includedir=-I..\..\..\src_base\mongoose79\.
tool_obj=OneMegaToBinance_build_dir\tool.cpp.obj 
tool_includedir=-I..\..\..\src_base\tool\.
jsoncpp_obj=OneMegaToBinance_build_dir\json_reader.cpp.obj OneMegaToBinance_build_dir\json_value.cpp.obj OneMegaToBinance_build_dir\json_writer.cpp.obj 
jsoncpp_includedir=-I..\..\..\src_base\jsoncpp\.
include_includedir=-I..\..\..\src_api\include\.
openssl_include_obj=OneMegaToBinance_build_dir\ApiKeyUtil.cpp.obj 
openssl_include_includedir=-I..\..\..\libs\openssl\1.1.0h\include\.
openssl_lib_lib=/libpath:..\..\..\libs\openssl\1.1.0h\static\windows_x64 crypto.lib ssl.lib Crypt32.lib 
openssl_lib_includedir= 
OneMegaToBinance_obj=OneMegaToBinance_build_dir\Link.cpp.obj 
OneMegaToBinance_includedir=-I.\.

all_objs=$(datastruct_obj) $(function_obj) $(mongoose79_obj) $(tool_obj) $(jsoncpp_obj) $(openssl_include_obj) $(OneMegaToBinance_obj) 

all_libs=$(openssl_lib_lib) 
INCLUDEDIR= $(datastruct_includedir)  $(function_includedir)  $(mongoose79_includedir)  $(tool_includedir)  $(jsoncpp_includedir)  $(include_includedir)  $(openssl_include_includedir)  $(openssl_lib_includedir)  $(OneMegaToBinance_includedir) 

OneMegaToBinance_build_dir\BigDigit.cpp.obj: ..\..\..\src_base\datastruct\BigDigit.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\datastruct\BigDigit.cpp /FoOneMegaToBinance_build_dir\BigDigit.cpp.obj
OneMegaToBinance_build_dir\CDate.cpp.obj: ..\..\..\src_base\datastruct\CDate.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\datastruct\CDate.cpp /FoOneMegaToBinance_build_dir\CDate.cpp.obj
OneMegaToBinance_build_dir\CErrorEngine.cpp.obj: ..\..\..\src_base\datastruct\CErrorEngine.cpp $(datastruct_include)
