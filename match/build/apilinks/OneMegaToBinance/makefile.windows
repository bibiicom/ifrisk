	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\datastruct\CSVToField.cpp /FoOneMegaToBinance_build_dir\CSVToField.cpp.obj
OneMegaToBinance_build_dir\FieldDescribe.cpp.obj: ..\..\..\src_base\datastruct\FieldDescribe.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\datastruct\FieldDescribe.cpp /FoOneMegaToBinance_build_dir\FieldDescribe.cpp.obj
OneMegaToBinance_build_dir\BaseFunction.cpp.obj: ..\..\..\src_base\function\BaseFunction.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\function\BaseFunction.cpp /FoOneMegaToBinance_build_dir\BaseFunction.cpp.obj
OneMegaToBinance_build_dir\Config.cpp.obj: ..\..\..\src_base\function\Config.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\function\Config.cpp /FoOneMegaToBinance_build_dir\Config.cpp.obj
OneMegaToBinance_build_dir\platform.cpp.obj: ..\..\..\src_base\function\platform.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\function\platform.cpp /FoOneMegaToBinance_build_dir\platform.cpp.obj
OneMegaToBinance_build_dir\printinfo.cpp.obj: ..\..\..\src_base\function\printinfo.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\function\printinfo.cpp /FoOneMegaToBinance_build_dir\printinfo.cpp.obj
OneMegaToBinance_build_dir\profile.cpp.obj: ..\..\..\src_base\function\profile.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\function\profile.cpp /FoOneMegaToBinance_build_dir\profile.cpp.obj
OneMegaToBinance_build_dir\utility.cpp.obj: ..\..\..\src_base\function\utility.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\function\utility.cpp /FoOneMegaToBinance_build_dir\utility.cpp.obj
OneMegaToBinance_build_dir\utils.cpp.obj: ..\..\..\src_base\function\utils.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\function\utils.cpp /FoOneMegaToBinance_build_dir\utils.cpp.obj
OneMegaToBinance_build_dir\version.cpp.obj: ..\..\..\src_base\function\version.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\function\version.cpp /FoOneMegaToBinance_build_dir\version.cpp.obj
OneMegaToBinance_build_dir\HttpClient.cpp.obj: ..\..\..\src_base\mongoose79\HttpClient.cpp $(mongoose79_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\mongoose79\HttpClient.cpp /FoOneMegaToBinance_build_dir\HttpClient.cpp.obj
OneMegaToBinance_build_dir\SMTPClient.cpp.obj: ..\..\..\src_base\mongoose79\SMTPClient.cpp $(mongoose79_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\mongoose79\SMTPClient.cpp /FoOneMegaToBinance_build_dir\SMTPClient.cpp.obj
OneMegaToBinance_build_dir\WSClient.cpp.obj: ..\..\..\src_base\mongoose79\WSClient.cpp $(mongoose79_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\mongoose79\WSClient.cpp /FoOneMegaToBinance_build_dir\WSClient.cpp.obj
OneMegaToBinance_build_dir\mongoose.c.obj: ..\..\..\src_base\mongoose79\mongoose.c $(mongoose79_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\mongoose79\mongoose.c /FoOneMegaToBinance_build_dir\mongoose.c.obj
OneMegaToBinance_build_dir\tool.cpp.obj: ..\..\..\src_base\tool\tool.cpp $(tool_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\tool\tool.cpp /FoOneMegaToBinance_build_dir\tool.cpp.obj
OneMegaToBinance_build_dir\json_reader.cpp.obj: ..\..\..\src_base\jsoncpp\json_reader.cpp $(jsoncpp_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\jsoncpp\json_reader.cpp /FoOneMegaToBinance_build_dir\json_reader.cpp.obj
OneMegaToBinance_build_dir\json_value.cpp.obj: ..\..\..\src_base\jsoncpp\json_value.cpp $(jsoncpp_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\jsoncpp\json_value.cpp /FoOneMegaToBinance_build_dir\json_value.cpp.obj
OneMegaToBinance_build_dir\json_writer.cpp.obj: ..\..\..\src_base\jsoncpp\json_writer.cpp $(jsoncpp_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\jsoncpp\json_writer.cpp /FoOneMegaToBinance_build_dir\json_writer.cpp.obj
OneMegaToBinance_build_dir\ApiKeyUtil.cpp.obj: ..\..\..\libs\openssl\1.1.0h\include\ApiKeyUtil.cpp $(openssl_include_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\libs\openssl\1.1.0h\include\ApiKeyUtil.cpp /FoOneMegaToBinance_build_dir\ApiKeyUtil.cpp.obj
OneMegaToBinance_build_dir\Link.cpp.obj: .\Link.cpp $(OneMegaToBinance_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c .\Link.cpp /FoOneMegaToBinance_build_dir\Link.cpp.obj

$(target): $(all_objs)
	$(LINK) $(DLLARFLAGS) -out:$@ -implib:.\.\OneMegaToBinance.lib $(all_objs) $(all_libs) $(LIBS)

clean:
	-$(DEL) $(datastruct_obj)
	-$(DEL) $(function_obj)
	-$(DEL) $(mongoose79_obj)
	-$(DEL) $(tool_obj)
	-$(DEL) $(jsoncpp_obj)
	-$(DEL) $(openssl_include_obj)
	-$(DEL) $(OneMegaToBinance_obj)

	-$(DEL) $(target)
	-$(DEL) .\.\OneMegaToBinance.lib
	-$(DEL) .\.\OneMegaToBinance.pdb
