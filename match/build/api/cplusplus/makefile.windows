OneMegaApi_build_dir\FieldMap.cpp.obj: ..\..\..\src_base\field\FieldMap.cpp $(field_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\field\FieldMap.cpp /FoOneMegaApi_build_dir\FieldMap.cpp.obj
OneMegaApi_build_dir\OutFogServiceApiWrapper.cpp.obj: ..\..\..\libs\ofserviceapi\ofapibase\OutFogServiceApiWrapper.cpp $(ofapibase_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\libs\ofserviceapi\ofapibase\OutFogServiceApiWrapper.cpp /FoOneMegaApi_build_dir\OutFogServiceApiWrapper.cpp.obj
OneMegaApi_build_dir\ApiImpl.cpp.obj: ..\..\..\src_api\api\ApiImpl.cpp $(api_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_api\api\ApiImpl.cpp /FoOneMegaApi_build_dir\ApiImpl.cpp.obj

$(target): $(all_objs)
	$(LINK) $(DLLARFLAGS) -out:$@ -implib:.\\OneMegaApi.lib $(all_objs) $(all_libs) $(LIBS)

clean:
	-$(DEL) $(function_obj)
	-$(DEL) $(datastruct_obj)
	-$(DEL) $(thread_obj)
	-$(DEL) $(xml_obj)
	-$(DEL) $(logger_obj)
	-$(DEL) $(netstruct_obj)
	-$(DEL) $(field_obj)
	-$(DEL) $(ofapibase_obj)
	-$(DEL) $(api_obj)

	-$(DEL) $(target)
	-$(DEL) .\\OneMegaApi.lib
	-$(DEL) .\\OneMegaApi.pdb
