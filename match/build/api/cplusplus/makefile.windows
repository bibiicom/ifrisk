	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\logger\CFilelogService.cpp /FoOneMegaApi_build_dir\CFilelogService.cpp.obj
OneMegaApi_build_dir\CLogger.cpp.obj: ..\..\..\src_base\logger\CLogger.cpp $(logger_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\logger\CLogger.cpp /FoOneMegaApi_build_dir\CLogger.cpp.obj
OneMegaApi_build_dir\CProbeLogger.cpp.obj: ..\..\..\src_base\logger\CProbeLogger.cpp $(logger_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\..\src_base\logger\CProbeLogger.cpp /FoOneMegaApi_build_dir\CProbeLogger.cpp.obj
