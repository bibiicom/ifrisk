<?xml version="1.0" encoding="gb2312"?>
!!enter api!!
!!let apiname=@apiname!!
!!let APINAME=@APINAME!!
!!let apiid=@apiid!!
!!let APIID=@APIID!!
!!leave!!
<project target="Link!!@apiname!!!!@apiid!!" targettype="dll" workdir="../cplusplus/" hasdebug="yes" hasmap="no" 
hasprofile="no" multithread="yes" warninglevel="2" model="../../../xmls/entity/" apiname="!!@apiname!!" APINAME="!!@APINAME!!" apiid="!!@apiid!!" APIID="!!@APIID!!">
	<cppflags>
		<cppflag name="DDEBUG_NOT_LOG"/>
		<cppflag name="OUTFOGSERVICE_API_IS_LIB"/>
		<cppflag name="LIB_OUTFOGSERVICE_API_EXPORT"/>
	</cppflags>

	<package dir="../../../src_base/datastruct"/>
	<package dir="../../../src_base/function"/>
	<package dir="../../../src_base/netstruct"/>
	<package dir="../../../src_base/field"/>
	
	<package dir="../../../libs/ofserviceapi" version="1.0" libpath=""/>
	<package dir="../../../src_api/include" prefix="!!@apiname!!!!@apiid!!"/>
	<package dir="../../../src_api/linkswap"/>
</project>
