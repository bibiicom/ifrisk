
CPP=cl
LINK=link
LIB32=lib 
PREP=cl -nologo -EP
COPY=copy /y
DEL=del
MAKE=nmake
ECHO=echo



	
	
ISLIB=N
DEFINES=-DWINDOWS -DMSVC
target=.\..\..\build\sinkdb\\sinkdb.exe

APPEND_CPPFLAGS=-nologo -EHsc -MTd -Od -Gm -Zi -FD -Zm200

PROFILE_CPPFLAGS=

WARNING_CPPFLAGS=-W3

CPPFLAGS=   -DDEBUG_NOT_LOG $(APPEND_CPPFLAGS) $(PROFILE_CPPFLAGS) $(WARNING_CPPFLAGS) $(DEFINES)
LIBS= kernel32.lib user32.lib gdi32.lib winspool.lib comdlg32.lib advapi32.lib shell32.lib ole32.lib oleaut32.lib uuid.lib odbc32.lib odbccp32.lib ws2_32.lib  

DEBUG_LDFLAGS=/DEBUG

MAP_LDFLAGS=

PROFILE_LDFLAGS=

WARNING_LDFLAGS=/WARN:2

LDFLAGS=    -nologo /FIXED:NO $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS) $(WARNING_LDFLAGS)
LIBARFLAGS=    -nologo $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)
DLLARFLAGS=    -nologo /dll $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)

all: code

code: clearoutput $(target)

clearoutput:
	@$(ECHO) Compiling...
	-mkdir  sinkdb_build_dir
	-mkdir  .\..\..\build\sinkdb\\
	
datastruct_obj=sinkdb_build_dir\BigDigit.cpp.obj sinkdb_build_dir\CDate.cpp.obj sinkdb_build_dir\CErrorEngine.cpp.obj sinkdb_build_dir\CSequence.cpp.obj sinkdb_build_dir\CSVParser.cpp.obj sinkdb_build_dir\CSVToField.cpp.obj sinkdb_build_dir\FieldDescribe.cpp.obj 
datastruct_includedir=-I..\..\src_base\datastruct\.
function_obj=sinkdb_build_dir\BaseFunction.cpp.obj sinkdb_build_dir\Config.cpp.obj sinkdb_build_dir\platform.cpp.obj sinkdb_build_dir\printinfo.cpp.obj sinkdb_build_dir\profile.cpp.obj sinkdb_build_dir\utility.cpp.obj sinkdb_build_dir\utils.cpp.obj sinkdb_build_dir\version.cpp.obj 
function_includedir=-I..\..\src_base\function\.
thread_obj=sinkdb_build_dir\Semaphore.cpp.obj sinkdb_build_dir\Thread.cpp.obj 
thread_includedir=-I..\..\src_base\thread\.
logger_obj=sinkdb_build_dir\CFilelogService.cpp.obj sinkdb_build_dir\CLogger.cpp.obj sinkdb_build_dir\CProbeLogger.cpp.obj sinkdb_build_dir\CSyslogService.cpp.obj sinkdb_build_dir\monitorIndex.cpp.obj 
logger_includedir=-I..\..\src_base\logger\.
jsoncpp_obj=sinkdb_build_dir\json_reader.cpp.obj sinkdb_build_dir\json_value.cpp.obj sinkdb_build_dir\json_writer.cpp.obj 
jsoncpp_includedir=-I..\..\src_base\jsoncpp\.
netstruct_obj=sinkdb_build_dir\errorDefine.cpp.obj sinkdb_build_dir\TableDefine.cpp.obj 
netstruct_includedir=-I..\..\src_base\netstruct\.
field_obj=sinkdb_build_dir\FieldData.cpp.obj sinkdb_build_dir\FieldMap.cpp.obj 
field_includedir=-I..\..\src_base\field\.
ofserviceapi_include_includedir=-I..\..\libs\ofserviceapi\1.0\include\.
ofapibase_obj=sinkdb_build_dir\OutFogServiceApiWrapper.cpp.obj 
ofapibase_includedir=-I..\..\libs\ofserviceapi\ofapibase\.
sqlapi_include_includedir=-I..\..\libs\sqlapi\4.1.3\include\.
sqlapi_lib_lib=/libpath:..\..\libs\sqlapi\4.1.3\.\windows_x64 sqlapi.lib 
sqlapi_lib_includedir= 
dbconnect_obj=sinkdb_build_dir\DbConnection.cpp.obj sinkdb_build_dir\DbHelper.cpp.obj 
dbconnect_includedir=-I..\..\libs\sqlapi\dbconnect\.
sinkdb_obj=sinkdb_build_dir\DelayMDB.cpp.obj sinkdb_build_dir\SinkDB.cpp.obj sinkdb_build_dir\SinkDBCSVWorker.cpp.obj sinkdb_build_dir\SinkDBDispatcher.cpp.obj sinkdb_build_dir\SinkDBEngine.cpp.obj sinkdb_build_dir\SinkDBSQLWorker.cpp.obj sinkdb_build_dir\TableSync.cpp.obj 
sinkdb_includedir=-I..\..\src\sinkdb\.

all_objs=$(datastruct_obj) $(function_obj) $(thread_obj) $(logger_obj) $(jsoncpp_obj) $(netstruct_obj) $(field_obj) $(ofapibase_obj) $(dbconnect_obj) $(sinkdb_obj) 

all_libs=$(sqlapi_lib_lib) 
INCLUDEDIR= $(datastruct_includedir)  $(function_includedir)  $(thread_includedir)  $(logger_includedir)  $(jsoncpp_includedir)  $(netstruct_includedir)  $(field_includedir)  $(ofserviceapi_include_includedir)  $(ofapibase_includedir)  $(sqlapi_include_includedir)  $(sqlapi_lib_includedir)  $(dbconnect_includedir)  $(sinkdb_includedir) 

sinkdb_build_dir\BigDigit.cpp.obj: ..\..\src_base\datastruct\BigDigit.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\src_base\datastruct\BigDigit.cpp /Fosinkdb_build_dir\BigDigit.cpp.obj
sinkdb_build_dir\CDate.cpp.obj: ..\..\src_base\datastruct\CDate.cpp $(datastruct_include)
