$(target): $(all_objs)
	$(LINK) $(LDFLAGS) -out:$@ $(all_objs) $(all_libs) $(LIBS)

clean:
	-$(DEL) $(datastruct_obj)
	-$(DEL) $(function_obj)
	-$(DEL) $(thread_obj)
	-$(DEL) $(logger_obj)
	-$(DEL) $(jsoncpp_obj)
	-$(DEL) $(netstruct_obj)
	-$(DEL) $(field_obj)
	-$(DEL) $(ofapibase_obj)
	-$(DEL) $(dbconnect_obj)
	-$(DEL) $(sinkdb_obj)

	-$(DEL) $(target)
	-$(DEL) .\..\..\build\sinkdb\\sinkdb.pdb
