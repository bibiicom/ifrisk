	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/thread/Semaphore.cpp -osinkdb_build_dir/Semaphore.cpp.o
sinkdb_build_dir/Thread.cpp.o: ../../src_base/thread/Thread.cpp $(thread_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/thread/Thread.cpp -osinkdb_build_dir/Thread.cpp.o
