	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/logger/CSyslogService.cpp -osinkdb_build_dir/CSyslogService.cpp.o
sinkdb_build_dir/monitorIndex.cpp.o: ../../src_base/logger/monitorIndex.cpp $(logger_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/logger/monitorIndex.cpp -osinkdb_build_dir/monitorIndex.cpp.o
sinkdb_build_dir/json_reader.cpp.o: ../../src_base/jsoncpp/json_reader.cpp $(jsoncpp_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/jsoncpp/json_reader.cpp -osinkdb_build_dir/json_reader.cpp.o
sinkdb_build_dir/json_value.cpp.o: ../../src_base/jsoncpp/json_value.cpp $(jsoncpp_include)
