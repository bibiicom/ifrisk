
CPP=g++ -fpic -std=c++11
LINK=g++
LIB32=ar -ru
PREP=g++ -E -P
COPY=cp
DEL=rm
MAKE=make
ECHO=echo



	
	
ISLIB=N
DEFINES=-DLINUX -DGCC
target=./../../build/sinkdb//sinkdb

APPEND_CPPFLAGS=-g3 -gdwarf-2 -O0 -pthread -m64

PROFILE_CPPFLAGS=

WARNING_CPPFLAGS=-Wall -Wno-sign-compare

CPPFLAGS=   -DDEBUG_NOT_LOG $(APPEND_CPPFLAGS) $(PROFILE_CPPFLAGS) $(WARNING_CPPFLAGS) $(DEFINES)
LIBS= -lpthread -lrt  

DEBUG_LDFLAGS=-g -O0 -m64

MAP_LDFLAGS=

PROFILE_LDFLAGS=

WARNING_LDFLAGS=-Wall -Wno-sign-compare

LDFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS) $(WARNING_LDFLAGS)
LIBARFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)
DLLARFLAGS=    -shared -Wl,-Bsymbolic -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)

all: code

code: clearoutput $(target)

clearoutput:
	@$(ECHO) Compiling...
	-mkdir -p sinkdb_build_dir
	-mkdir -p ./../../build/sinkdb//
	
datastruct_obj=sinkdb_build_dir/BigDigit.cpp.o sinkdb_build_dir/CDate.cpp.o sinkdb_build_dir/CErrorEngine.cpp.o sinkdb_build_dir/CSequence.cpp.o sinkdb_build_dir/CSVParser.cpp.o sinkdb_build_dir/CSVToField.cpp.o sinkdb_build_dir/FieldDescribe.cpp.o 
datastruct_includedir=-I../../src_base/datastruct/.
function_obj=sinkdb_build_dir/BaseFunction.cpp.o sinkdb_build_dir/Config.cpp.o sinkdb_build_dir/platform.cpp.o sinkdb_build_dir/printinfo.cpp.o sinkdb_build_dir/profile.cpp.o sinkdb_build_dir/utility.cpp.o sinkdb_build_dir/utils.cpp.o sinkdb_build_dir/version.cpp.o 
function_includedir=-I../../src_base/function/.
thread_obj=sinkdb_build_dir/Semaphore.cpp.o sinkdb_build_dir/Thread.cpp.o 
thread_includedir=-I../../src_base/thread/.
logger_obj=sinkdb_build_dir/CFilelogService.cpp.o sinkdb_build_dir/CLogger.cpp.o sinkdb_build_dir/CProbeLogger.cpp.o sinkdb_build_dir/CSyslogService.cpp.o sinkdb_build_dir/monitorIndex.cpp.o 
logger_includedir=-I../../src_base/logger/.
jsoncpp_obj=sinkdb_build_dir/json_reader.cpp.o sinkdb_build_dir/json_value.cpp.o sinkdb_build_dir/json_writer.cpp.o 
jsoncpp_includedir=-I../../src_base/jsoncpp/.
netstruct_obj=sinkdb_build_dir/errorDefine.cpp.o sinkdb_build_dir/TableDefine.cpp.o 
netstruct_includedir=-I../../src_base/netstruct/.
field_obj=sinkdb_build_dir/FieldData.cpp.o sinkdb_build_dir/FieldMap.cpp.o 
field_includedir=-I../../src_base/field/.
ofserviceapi_include_includedir=-I../../libs/ofserviceapi/1.0/include/.
ofapibase_obj=sinkdb_build_dir/OutFogServiceApiWrapper.cpp.o 
ofapibase_includedir=-I../../libs/ofserviceapi/ofapibase/.
sqlapi_include_includedir=-I../../libs/sqlapi/4.1.3/include/.
sqlapi_lib_lib=-L../../libs/sqlapi/4.1.3/./linux_x64 -lmysqlclient_r -lsqlapi ../../libs/sqlapi/4.1.3/./linux_x64/libmysqlclient.so.18 
sqlapi_lib_includedir= 
dbconnect_obj=sinkdb_build_dir/DbConnection.cpp.o sinkdb_build_dir/DbHelper.cpp.o 
dbconnect_includedir=-I../../libs/sqlapi/dbconnect/.
sinkdb_obj=sinkdb_build_dir/DelayMDB.cpp.o sinkdb_build_dir/SinkDB.cpp.o sinkdb_build_dir/SinkDBCSVWorker.cpp.o sinkdb_build_dir/SinkDBDispatcher.cpp.o sinkdb_build_dir/SinkDBEngine.cpp.o sinkdb_build_dir/SinkDBSQLWorker.cpp.o sinkdb_build_dir/TableSync.cpp.o 
sinkdb_includedir=-I../../src/sinkdb/.

all_objs=$(datastruct_obj) $(function_obj) $(thread_obj) $(logger_obj) $(jsoncpp_obj) $(netstruct_obj) $(field_obj) $(ofapibase_obj) $(dbconnect_obj) $(sinkdb_obj) 

all_libs=$(sqlapi_lib_lib) 
INCLUDEDIR= $(datastruct_includedir)  $(function_includedir)  $(thread_includedir)  $(logger_includedir)  $(jsoncpp_includedir)  $(netstruct_includedir)  $(field_includedir)  $(ofserviceapi_include_includedir)  $(ofapibase_includedir)  $(sqlapi_include_includedir)  $(sqlapi_lib_includedir)  $(dbconnect_includedir)  $(sinkdb_includedir) 

sinkdb_build_dir/BigDigit.cpp.o: ../../src_base/datastruct/BigDigit.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/datastruct/BigDigit.cpp -osinkdb_build_dir/BigDigit.cpp.o
sinkdb_build_dir/CDate.cpp.o: ../../src_base/datastruct/CDate.cpp $(datastruct_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/datastruct/CDate.cpp -osinkdb_build_dir/CDate.cpp.o
