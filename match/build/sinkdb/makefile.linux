	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/function/utility.cpp -osinkdb_build_dir/utility.cpp.o
sinkdb_build_dir/utils.cpp.o: ../../src_base/function/utils.cpp $(function_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/function/utils.cpp -osinkdb_build_dir/utils.cpp.o
sinkdb_build_dir/version.cpp.o: ../../src_base/function/version.cpp $(function_include)
