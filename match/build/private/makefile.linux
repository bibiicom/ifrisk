
CPP=g++ -fpic -std=c++11
LINK=g++
LIB32=ar -ru
PREP=g++ -E -P
COPY=cp
DEL=rm
MAKE=make
ECHO=echo



	
	
ISLIB=N
DEFINES=-DLINUX -DGCC
target=././/private

APPEND_CPPFLAGS=-g3 -gdwarf-2 -O0 -pthread -m64

PROFILE_CPPFLAGS=

WARNING_CPPFLAGS=-Wall -Wno-sign-compare

CPPFLAGS=   -DDEBUG_NOT_LOG $(APPEND_CPPFLAGS) $(PROFILE_CPPFLAGS) $(WARNING_CPPFLAGS) $(DEFINES)
LIBS= -lpthread -lrt  

DEBUG_LDFLAGS=-g -O0 -m64

MAP_LDFLAGS=

PROFILE_LDFLAGS=

WARNING_LDFLAGS=-Wall -Wno-sign-compare

LDFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS) $(WARNING_LDFLAGS)
LIBARFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)
DLLARFLAGS=    -shared -Wl,-Bsymbolic -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)

all: code

code: clearoutput $(target)

clearoutput:
	@$(ECHO) Compiling...
	-mkdir -p private_build_dir
	-mkdir -p ././/
	
crypt_obj=private_build_dir/cryptUtility.cpp.o private_build_dir/Des.cpp.o private_build_dir/hexEncode.cpp.o private_build_dir/md5Handler.cpp.o 
crypt_includedir=-I../../src_base/crypt/.
datastruct_obj=private_build_dir/BigDigit.cpp.o private_build_dir/CDate.cpp.o private_build_dir/CErrorEngine.cpp.o private_build_dir/CSequence.cpp.o private_build_dir/CSVParser.cpp.o private_build_dir/CSVToField.cpp.o private_build_dir/FieldDescribe.cpp.o 
datastruct_includedir=-I../../src_base/datastruct/.
function_obj=private_build_dir/BaseFunction.cpp.o private_build_dir/Config.cpp.o private_build_dir/platform.cpp.o private_build_dir/printinfo.cpp.o private_build_dir/profile.cpp.o private_build_dir/utility.cpp.o private_build_dir/utils.cpp.o private_build_dir/version.cpp.o 
function_includedir=-I../../src_base/function/.
logger_obj=private_build_dir/CFilelogService.cpp.o private_build_dir/CLogger.cpp.o private_build_dir/CProbeLogger.cpp.o private_build_dir/CSyslogService.cpp.o private_build_dir/monitorIndex.cpp.o 
logger_includedir=-I../../src_base/logger/.
netstruct_obj=private_build_dir/errorDefine.cpp.o private_build_dir/TableDefine.cpp.o 
netstruct_includedir=-I../../src_base/netstruct/.
field_obj=private_build_dir/FieldData.cpp.o private_build_dir/FieldMap.cpp.o 
field_includedir=-I../../src_base/field/.
mdbbase_obj=private_build_dir/mdb.cpp.o private_build_dir/mdbAction.cpp.o private_build_dir/mdbIter.cpp.o private_build_dir/mdbLog.cpp.o private_build_dir/mdbSearch.cpp.o private_build_dir/mdbStruct.cpp.o private_build_dir/mdbTable.cpp.o 
mdbbase_includedir=-I../../src_base/mdb/mdbbase/.
mdbstruct_obj=private_build_dir/Allocator.cpp.o private_build_dir/CAVLTree.cpp.o private_build_dir/CBaseObject.cpp.o private_build_dir/CDatabaseDataFactory.cpp.o private_build_dir/CDatabaseResource.cpp.o private_build_dir/CDoubleHash.cpp.o private_build_dir/CFixMem.cpp.o private_build_dir/CHashIndex.cpp.o private_build_dir/CTransaction.cpp.o 
mdbstruct_includedir=-I../../src_base/mdb/mdbstruct/.
ofserviceapi_include_includedir=-I../../libs/ofserviceapi/1.0/include/.
ofapibase_obj=private_build_dir/OutFogServiceApiWrapper.cpp.o 
ofapibase_includedir=-I../../libs/ofserviceapi/ofapibase/.
modMarketData_obj=private_build_dir/CServiceTimer.cpp.o private_build_dir/MarketDataService.cpp.o private_build_dir/MarketDataTimer.cpp.o private_build_dir/MarketDataTriggers.cpp.o 
modMarketData_includedir=-I../../src/modMarketData/.
serviceLogin_obj=private_build_dir/LoginService.cpp.o private_build_dir/LoginServiceInterface.cpp.o 
serviceLogin_includedir=-I../../src/service/serviceLogin/.
service_obj=private_build_dir/ServiceShare.cpp.o private_build_dir/tradingTools.cpp.o 
service_includedir=-I../../src/service/.
private_obj=private_build_dir/App.cpp.o 
private_includedir=-I../../src/private/.

all_objs=$(crypt_obj) $(datastruct_obj) $(function_obj) $(logger_obj) $(netstruct_obj) $(field_obj) $(mdbbase_obj) $(mdbstruct_obj) $(ofapibase_obj) $(modMarketData_obj) $(serviceLogin_obj) $(service_obj) $(private_obj) 

all_libs=
INCLUDEDIR= $(crypt_includedir)  $(datastruct_includedir)  $(function_includedir)  $(logger_includedir)  $(netstruct_includedir)  $(field_includedir)  $(mdbbase_includedir)  $(mdbstruct_includedir)  $(ofserviceapi_include_includedir)  $(ofapibase_includedir)  $(modMarketData_includedir)  $(serviceLogin_includedir)  $(service_includedir)  $(private_includedir) 

private_build_dir/cryptUtility.cpp.o: ../../src_base/crypt/cryptUtility.cpp $(crypt_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/crypt/cryptUtility.cpp -oprivate_build_dir/cryptUtility.cpp.o
