
CPP=g++ -fpic -std=c++11
LINK=g++
LIB32=ar -ru
PREP=g++ -E -P
COPY=cp
DEL=rm
MAKE=make
ECHO=echo



	
	
ISLIB=N
DEFINES=-DLINUX -DGCC
target=././/triggerorder

APPEND_CPPFLAGS=-g3 -gdwarf-2 -O0 -pthread -m64

PROFILE_CPPFLAGS=

WARNING_CPPFLAGS=-Wall -Wno-sign-compare

CPPFLAGS=   -DDEBUG_NOT_LOG $(APPEND_CPPFLAGS) $(PROFILE_CPPFLAGS) $(WARNING_CPPFLAGS) $(DEFINES)
LIBS= -lpthread -lrt  

DEBUG_LDFLAGS=-g -O0 -m64

MAP_LDFLAGS=

PROFILE_LDFLAGS=

WARNING_LDFLAGS=-Wall -Wno-sign-compare

LDFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS) $(WARNING_LDFLAGS)
LIBARFLAGS=    -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)
DLLARFLAGS=    -shared -Wl,-Bsymbolic -ldl $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)

all: code

code: clearoutput $(target)

clearoutput:
	@$(ECHO) Compiling...
	-mkdir -p triggerorder_build_dir
	-mkdir -p ././/
	
crypt_obj=triggerorder_build_dir/cryptUtility.cpp.o triggerorder_build_dir/Des.cpp.o triggerorder_build_dir/hexEncode.cpp.o triggerorder_build_dir/md5Handler.cpp.o 
crypt_includedir=-I../../src_base/crypt/.
datastruct_obj=triggerorder_build_dir/BigDigit.cpp.o triggerorder_build_dir/CDate.cpp.o triggerorder_build_dir/CErrorEngine.cpp.o triggerorder_build_dir/CSequence.cpp.o triggerorder_build_dir/CSVParser.cpp.o triggerorder_build_dir/CSVToField.cpp.o triggerorder_build_dir/FieldDescribe.cpp.o 
datastruct_includedir=-I../../src_base/datastruct/.
function_obj=triggerorder_build_dir/BaseFunction.cpp.o triggerorder_build_dir/Config.cpp.o triggerorder_build_dir/platform.cpp.o triggerorder_build_dir/printinfo.cpp.o triggerorder_build_dir/profile.cpp.o triggerorder_build_dir/utility.cpp.o triggerorder_build_dir/utils.cpp.o triggerorder_build_dir/version.cpp.o 
function_includedir=-I../../src_base/function/.
logger_obj=triggerorder_build_dir/CFilelogService.cpp.o triggerorder_build_dir/CLogger.cpp.o triggerorder_build_dir/CProbeLogger.cpp.o triggerorder_build_dir/CSyslogService.cpp.o triggerorder_build_dir/monitorIndex.cpp.o 
logger_includedir=-I../../src_base/logger/.
netstruct_obj=triggerorder_build_dir/errorDefine.cpp.o triggerorder_build_dir/TableDefine.cpp.o 
netstruct_includedir=-I../../src_base/netstruct/.
field_obj=triggerorder_build_dir/FieldData.cpp.o triggerorder_build_dir/FieldMap.cpp.o 
field_includedir=-I../../src_base/field/.
mdbbase_obj=triggerorder_build_dir/mdb.cpp.o triggerorder_build_dir/mdbAction.cpp.o triggerorder_build_dir/mdbIter.cpp.o triggerorder_build_dir/mdbLog.cpp.o triggerorder_build_dir/mdbSearch.cpp.o triggerorder_build_dir/mdbStruct.cpp.o triggerorder_build_dir/mdbTable.cpp.o 
mdbbase_includedir=-I../../src_base/mdb/mdbbase/.
mdbstruct_obj=triggerorder_build_dir/Allocator.cpp.o triggerorder_build_dir/CAVLTree.cpp.o triggerorder_build_dir/CBaseObject.cpp.o triggerorder_build_dir/CDatabaseDataFactory.cpp.o triggerorder_build_dir/CDatabaseResource.cpp.o triggerorder_build_dir/CDoubleHash.cpp.o triggerorder_build_dir/CFixMem.cpp.o triggerorder_build_dir/CHashIndex.cpp.o triggerorder_build_dir/CTransaction.cpp.o 
mdbstruct_includedir=-I../../src_base/mdb/mdbstruct/.
ofserviceapi_include_includedir=-I../../libs/ofserviceapi/1.0/include/.
ofapibase_obj=triggerorder_build_dir/OutFogServiceApiWrapper.cpp.o 
ofapibase_includedir=-I../../libs/ofserviceapi/ofapibase/.
triggerorder_obj=triggerorder_build_dir/CallbackWorker.cpp.o triggerorder_build_dir/StopOrderWorker.cpp.o triggerorder_build_dir/TriggerOrder.cpp.o 
triggerorder_includedir=-I../../src/triggerorder/.

all_objs=$(crypt_obj) $(datastruct_obj) $(function_obj) $(logger_obj) $(netstruct_obj) $(field_obj) $(mdbbase_obj) $(mdbstruct_obj) $(ofapibase_obj) $(triggerorder_obj) 

all_libs=
INCLUDEDIR= $(crypt_includedir)  $(datastruct_includedir)  $(function_includedir)  $(logger_includedir)  $(netstruct_includedir)  $(field_includedir)  $(mdbbase_includedir)  $(mdbstruct_includedir)  $(ofserviceapi_include_includedir)  $(ofapibase_includedir)  $(triggerorder_includedir) 

triggerorder_build_dir/cryptUtility.cpp.o: ../../src_base/crypt/cryptUtility.cpp $(crypt_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/crypt/cryptUtility.cpp -otriggerorder_build_dir/cryptUtility.cpp.o
triggerorder_build_dir/Des.cpp.o: ../../src_base/crypt/Des.cpp $(crypt_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ../../src_base/crypt/Des.cpp -otriggerorder_build_dir/Des.cpp.o
