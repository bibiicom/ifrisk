	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\src\marketmaker\MarketWorker.cpp /Fomarketmaker_build_dir\MarketWorker.cpp.obj

$(target): $(all_objs)
	$(LINK) $(LDFLAGS) -out:$@ $(all_objs) $(all_libs) $(LIBS)

clean:
	-$(DEL) $(crypt_obj)
	-$(DEL) $(datastruct_obj)
	-$(DEL) $(function_obj)
	-$(DEL) $(logger_obj)
	-$(DEL) $(netstruct_obj)
	-$(DEL) $(field_obj)
	-$(DEL) $(ofapibase_obj)
	-$(DEL) $(marketmaker_obj)

	-$(DEL) $(target)
	-$(DEL) .\\marketmaker.pdb
