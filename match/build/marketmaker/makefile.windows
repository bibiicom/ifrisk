
CPP=cl
LINK=link
LIB32=lib 
PREP=cl -nologo -EP
COPY=copy /y
DEL=del
MAKE=nmake
ECHO=echo



	
	
ISLIB=N
DEFINES=-DWINDOWS -DMSVC
target=.\\marketmaker.exe

APPEND_CPPFLAGS=-nologo -EHsc -MTd -Od -Gm -Zi -FD -Zm200

PROFILE_CPPFLAGS=

WARNING_CPPFLAGS=-W3

CPPFLAGS=   -DDEBUG_NOT_LOG $(APPEND_CPPFLAGS) $(PROFILE_CPPFLAGS) $(WARNING_CPPFLAGS) $(DEFINES)
LIBS= kernel32.lib user32.lib gdi32.lib winspool.lib comdlg32.lib advapi32.lib shell32.lib ole32.lib oleaut32.lib uuid.lib odbc32.lib odbccp32.lib ws2_32.lib  

DEBUG_LDFLAGS=/DEBUG

MAP_LDFLAGS=

PROFILE_LDFLAGS=

WARNING_LDFLAGS=/WARN:2

LDFLAGS=    -nologo /FIXED:NO $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS) $(WARNING_LDFLAGS)
LIBARFLAGS=    -nologo $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)
DLLARFLAGS=    -nologo /dll $(MAP_LDFLAGS) $(DEBUG_LDFLAGS) $(PROFILE_LDFLAGS)

all: code

code: clearoutput $(target)

clearoutput:
	@$(ECHO) Compiling...
	-mkdir  marketmaker_build_dir
	-mkdir  .\\
	
crypt_obj=marketmaker_build_dir\cryptUtility.cpp.obj marketmaker_build_dir\Des.cpp.obj marketmaker_build_dir\hexEncode.cpp.obj marketmaker_build_dir\md5Handler.cpp.obj 
crypt_includedir=-I..\..\src_base\crypt\.
datastruct_obj=marketmaker_build_dir\BigDigit.cpp.obj marketmaker_build_dir\CDate.cpp.obj marketmaker_build_dir\CErrorEngine.cpp.obj marketmaker_build_dir\CSequence.cpp.obj marketmaker_build_dir\CSVParser.cpp.obj marketmaker_build_dir\CSVToField.cpp.obj marketmaker_build_dir\FieldDescribe.cpp.obj 
datastruct_includedir=-I..\..\src_base\datastruct\.
function_obj=marketmaker_build_dir\BaseFunction.cpp.obj marketmaker_build_dir\Config.cpp.obj marketmaker_build_dir\platform.cpp.obj marketmaker_build_dir\printinfo.cpp.obj marketmaker_build_dir\profile.cpp.obj marketmaker_build_dir\utility.cpp.obj marketmaker_build_dir\utils.cpp.obj marketmaker_build_dir\version.cpp.obj 
function_includedir=-I..\..\src_base\function\.
logger_obj=marketmaker_build_dir\CFilelogService.cpp.obj marketmaker_build_dir\CLogger.cpp.obj marketmaker_build_dir\CProbeLogger.cpp.obj marketmaker_build_dir\CSyslogService.cpp.obj marketmaker_build_dir\monitorIndex.cpp.obj 
logger_includedir=-I..\..\src_base\logger\.
netstruct_obj=marketmaker_build_dir\errorDefine.cpp.obj marketmaker_build_dir\TableDefine.cpp.obj 
netstruct_includedir=-I..\..\src_base\netstruct\.
field_obj=marketmaker_build_dir\FieldData.cpp.obj marketmaker_build_dir\FieldMap.cpp.obj 
field_includedir=-I..\..\src_base\field\.
ofserviceapi_include_includedir=-I..\..\libs\ofserviceapi\1.0\include\.
ofapibase_obj=marketmaker_build_dir\OutFogServiceApiWrapper.cpp.obj 
ofapibase_includedir=-I..\..\libs\ofserviceapi\ofapibase\.
marketmaker_obj=marketmaker_build_dir\FastWorker.cpp.obj marketmaker_build_dir\IndexWorker.cpp.obj marketmaker_build_dir\Main.cpp.obj marketmaker_build_dir\MarketWorker.cpp.obj 
marketmaker_includedir=-I..\..\src\marketmaker\.

all_objs=$(crypt_obj) $(datastruct_obj) $(function_obj) $(logger_obj) $(netstruct_obj) $(field_obj) $(ofapibase_obj) $(marketmaker_obj) 

all_libs=
INCLUDEDIR= $(crypt_includedir)  $(datastruct_includedir)  $(function_includedir)  $(logger_includedir)  $(netstruct_includedir)  $(field_includedir)  $(ofserviceapi_include_includedir)  $(ofapibase_includedir)  $(marketmaker_includedir) 

marketmaker_build_dir\cryptUtility.cpp.obj: ..\..\src_base\crypt\cryptUtility.cpp $(crypt_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\src_base\crypt\cryptUtility.cpp /Fomarketmaker_build_dir\cryptUtility.cpp.obj
marketmaker_build_dir\Des.cpp.obj: ..\..\src_base\crypt\Des.cpp $(crypt_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\src_base\crypt\Des.cpp /Fomarketmaker_build_dir\Des.cpp.obj
marketmaker_build_dir\hexEncode.cpp.obj: ..\..\src_base\crypt\hexEncode.cpp $(crypt_include)
	$(CPP) $(CPPFLAGS) $(INCLUDEDIR) -c ..\..\src_base\crypt\hexEncode.cpp /Fomarketmaker_build_dir\hexEncode.cpp.obj
