bool C!!@tableName!!Factory::removeByPK(!!travel parameter!!!!if (@pumpid!=0)!!, !!endif!!const !!command getReadOnlyEntityTypeName(@name);!!!!show_string (char *)strResult.c_str()!!& !!@name!!!!next!!, CTransaction *pTransaction)
{
	C!!@tableName!! *pOriginal!!@tableName!!;
	pOriginal!!@tableName!! = find!!@name!!(!!travel parameter!!!!if (@pumpid!=0)!!, !!endif!!!!@name!!!!next!!);
	if (pOriginal!!@tableName!! == NULL)
		return false;
	remove(pOriginal!!@tableName!!, pTransaction);
	return true;
}

C!!@tableName!! *C!!@tableName!!Factory::findByPK(C!!@tableName!!Field *p!!@tableName!!)
{
	return findByPK(!!travel parameter!!!!if @pumpid!=0!!, !!endif!!p!!@tableName!!->!!@name!!!!next!!);
}

C!!@tableName!! *C!!@tableName!!Factory::findByPK(C!!@tableName!! *p!!@tableName!!)
{
	return findByPK(!!travel parameter!!!!if @pumpid!=0!!, !!endif!!p!!@tableName!!->!!@name!!!!next!!);
}

bool C!!@tableName!!Factory::isPK(const char* pName)
{
	!!travel parameter!!
	if (!strcmp(pName, "!!@name!!"))
		return true;
	!!next!!
	return false;
}

bool C!!@tableName!!Factory::retrieveByPK(CWriteable!!@tableName!! *p!!@tableName!!)
{
	C!!@tableName!! *pOriginal!!@tableName!!;
	pOriginal!!@tableName!! = findByPK(p!!@tableName!!);
	if (pOriginal!!@tableName!! == NULL)
		return false;
	retrieve(pOriginal!!@tableName!!, p!!@tableName!!);
	return true;
}

C!!@tableName!! *C!!@tableName!!Factory::addByPK(CWriteable!!@tableName!! *p!!@tableName!!, CTransaction *pTransaction)
{
	C!!@tableName!! *pOriginal!!@tableName!!;
	pOriginal!!@tableName!! = findByPK(p!!@tableName!!);
	if (pOriginal!!@tableName!! != NULL)
		return NULL;
	return add(p!!@tableName!!, pTransaction);
}

bool C!!@tableName!!Factory::updateByPK(CWriteable!!@tableName!! *p!!@tableName!!, CTransaction *pTransaction)
{
	C!!@tableName!! *pOriginal!!@tableName!!;
	pOriginal!!@tableName!! = findByPK(p!!@tableName!!);
	if (pOriginal!!@tableName!! == NULL)
		return false;
	p!!@tableName!!->calAllHash();
	update(pOriginal!!@tableName!!, p!!@tableName!!, pTransaction);
	return true;
}

C!!@tableName!!* C!!@tableName!!Factory::addOrUpdateByPK(CWriteable!!@tableName!! *p!!@tableName!!, CTransaction *pTransaction)
{
	C!!@tableName!! *pOriginal!!@tableName!!;
	pOriginal!!@tableName!! = findByPK(p!!@tableName!!);
	if (pOriginal!!@tableName!! == NULL)
		return add(p!!@tableName!!, pTransaction);
	p!!@tableName!!->calAllHash();
	update(pOriginal!!@tableName!!, p!!@tableName!!, pTransaction);
	return pOriginal!!@tableName!!;
}

bool C!!@tableName!!Factory::removeByPK(C!!@tableName!! *p!!@tableName!!, CTransaction *pTransaction)
{
	C!!@tableName!! *pOriginal!!@tableName!!;
	pOriginal!!@tableName!! = findByPK(p!!@tableName!!);
	if (pOriginal!!@tableName!! == NULL)
		return false;
	remove(pOriginal!!@tableName!!, pTransaction);
	return true;
}

bool C!!@tableName!!Factory::removeByPK(C!!@tableName!!Field *p!!@tableName!!, CTransaction *pTransaction)
{
	C!!@tableName!! *pOriginal!!@tableName!!;
	pOriginal!!@tableName!! = findByPK(p!!@tableName!!);
	if (pOriginal!!@tableName!! == NULL)
		return false;
	Copy!!@tableName!!Entity(p!!@tableName!!, pOriginal!!@tableName!!);
	remove(pOriginal!!@tableName!!, pTransaction);
	return true;
}
	!!endif!!
	!!else!!!!** if (!strcmp(@searchUnique,"yes"))!!



C!!@tableName!!* C!!@tableName!!Factory::findFirst!!@name!!(!!travel parameter!!!!if (@pumpid!=0)!!, !!endif!!const !!command getReadOnlyEntityTypeName(@name);!!!!show_string (char *)strResult.c_str()!!& !!@name!!!!next!!)
{
	pLastFoundInSearch!!@name!! = NULL;
	///芝村侭嗤議臥儂峙
	!!let searchName=@name!!
	!!travel parameter!!
	query!!@name!!InSearch!!@searchName!! = !!@name!!.getValue();
	!!next!!
!!if !valid_name("hashIndexName")!!
!!if strcmp(@indexName,"noIndex")!!
	///功象歌方才髪福峙⇧譜崔喘噐曳熟議斤嵆議光倖蛍楚
	C!!@tableName!! *the!!@tableName!!;
	!!travel parameter!!
	compareObject.!!@name!! = !!@name!!.getValue();
	!!next!!
	!!travel default!!
	compareObject.!!@name!! = !!@value!!;
	!!next!!

	///壓沫哈嶄儖孀及匯倖諾怎訳周議
	pLastFoundInSearch!!@name!! = p!!@indexName!!->searchFirstGreatEqual(&compareObject);

	///泌惚短嗤孀欺⇧夸卦指
	if (pLastFoundInSearch!!@name!! == NULL)
		return NULL;

	///資函孀欺議斤嵆
	the!!@tableName!! = (C!!@tableName!! *)(pLastFoundInSearch!!@name!!->pObject);

	///泌惚嗤匯倖訳周音諾怎⇧夸払移卦指
	!!travel parameter!!
	!!if !strcmp(@checkParameter,"yes")!!
	if (compare(the!!@tableName!!->!!@name!!.getValue(), !!@name!!.getValue()))
	{
		pLastFoundInSearch!!@searchName!! = NULL;
		return NULL;
	}
	!!endif!!
	!!next!!
	!!travel default!!
	!!if !strcmp(@checkDefault, "yes")!!
	if (compare(the!!@tableName!!->!!@name!!, !!@value!!))
	{
		pLastFoundInSearch!!@searchName!! = NULL;
		return NULL;
	}
	!!endif!!
	!!next!!

	return the!!@tableName!!;
!!else!!!!** if strcmp(@indexName,"noIndex")!!
	///泌惚匯倖斤嵆匆短嗤⇧祥卦指払移
	pLastFoundInSearch!!@name!! = (C!!@tableName!! *)(pMem->getFirst());

	if (pLastFoundInSearch!!@name!! == NULL)
		return NULL;

	///泌惚及匯倖音屎鳩⇧夸聞喘findNext!!@searchName!!栖儖孀和匯倖
	!!travel parameter!!
	!!if !strcmp(@checkParameter,"yes")!!
	if (compare(pLastFoundInSearch!!@searchName!!->!!@name!!.getValue(), !!@name!!.getValue()))
		return findNext!!@searchName!!();
	!!endif!!
	!!next!!
	!!travel default!!
	!!if !strcmp(@checkDefault,"yes")!!
	if (compare(pLastFoundInSearch!!@searchName!!->!!@name!!, !!@value!!))
		return findNext!!@searchName!!();
	!!endif!!
	!!next!!

	return pLastFoundInSearch!!@name!!;
!!endif!!!!** if strcmp(@indexName,"noIndex")!!
!!endif!!!!** !valid_name("hashIndexName")!!
}

C!!@tableName!! *C!!@tableName!!Factory::findNext!!@name!!()
{
	///珊短嗤蝕兵臥孀⇧賜宀厮将孀欺恷朔匯倖阻⇧祥羨軸卦指
	if (pLastFoundInSearch!!@name!! == NULL)
		return NULL;

!!if !valid_name("hashIndexName")!!
!!if strcmp(@indexName,"noIndex")!!
	C!!@tableName!! *the!!@tableName!!;

	///孀和匯倖准泣⇧泌惚短嗤⇧夸臥孀潤崩
	pLastFoundInSearch!!@name!! = p!!@indexName!!->getNextNode(pLastFoundInSearch!!@name!!);
	if (pLastFoundInSearch!!@name!! == NULL)
		return NULL;

	the!!@tableName!! = (C!!@tableName!! *)(pLastFoundInSearch!!@name!!->pObject);

	///泌惚嗤匯倖訳周音諾怎⇧夸払移卦指
	!!travel parameter!!
	!!if !strcmp(@checkParameter,"yes")!!
	if (compare(the!!@tableName!!->!!@name!!, query!!@name!!InSearch!!@searchName!!))
	{
		pLastFoundInSearch!!@searchName!! = NULL;
		return NULL;
	}
	!!endif!!
	!!next!!
	!!travel default!!
	!!if !strcmp(@checkDefault,"yes")!!
	if (compare(the!!@tableName!!->!!@name!!, !!@value!!))
	{
		pLastFoundInSearch!!@searchName!! = NULL;
		return NULL;
	}
	!!endif!!
	!!next!!

	///卦指孀欺議潤惚
	return the!!@tableName!!;
!!else!!!!** strcmp(@indexName,"noIndex")!!
	///郡鹸晦編儖孀
	for (;;)
	{
		///泌惚厮将短嗤和匯倖阻⇧夸払移卦指
		pLastFoundInSearch!!@name!! = (C!!@tableName!! *)(pMem->getNext());
		if (pLastFoundInSearch!!@name!! == NULL)
			return NULL;

		///泌惚匯倖訳周音諾怎⇧夸晦編和匯倖
		!!travel parameter!!
		!!if !strcmp(@checkParameter, "yes")!!
		if (compare(pLastFoundInSearch!!@searchName!!->!!@name!!, query!!@name!!InSearch!!@searchName!!))
			continue;
		!!endif!!
		!!next!!
		!!travel default!!
		!!if !strcmp(@checkDefault,"yes")!!
		if (compare(pLastFoundInSearch!!@searchName!!->!!@name!!, !!@value!!))
			continue;
		!!endif!!
		!!next!!
		///卦指孀欺議潤惚
		return pLastFoundInSearch!!@searchName!!;
	}
!!endif!!!!** strcmp(@indexName,"noIndex")!!
!!endif!!!!** !valid_name("hashIndexName"))!!
}

	!!endif!!!!** if (!strcmp(@searchUnique,"yes"))!!
