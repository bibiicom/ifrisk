!!include function.itmp!!
!!enter system!!
/////////////////////////////////////////////////////////////////////////
///mdbResources.cpp
///实现了若干内存数据资源，可以放置于事务中
/////////////////////////////////////////////////////////////////////////

#include "mdbAction.h"

!!travel tables!!
!!if !strcmp(@hasTable,"yes")!!
!!command resetEntityMap();!!
!!travel fields!!
!!command addEntity(@name,@type)!!
!!next!!

CMemoryStack<C!!@name!!Resource> C!!@name!!Resource::resourceList;

C!!@name!!Resource * C!!@name!!Resource::alloc(int type, C!!@name!!Factory *pFactory, C!!@name!! *pObject)
{
	C!!@name!!Resource *pResource=resourceList.alloc();
	pResource->init(type,pFactory,pObject);
	return pResource;
}

void C!!@name!!Resource::free(void)
{
	resourceList.free(this);
}

C!!@name!!Resource::C!!@name!!Resource(void)
{
}
!!++!!
C!!@name!!Resource::C!!@name!!Resource(int type, C!!@name!!Factory *pFactory, C!!@name!! *pObject, CWriteable!!@name!! *pWriteableObject):CDatabaseResource(type)
{
	this->pFactory=pFactory;
	this->ref=pObject;
	if (pFactory==NULL)
	{
		EMERGENCY_EXIT("Invalid pFactory while creating resource");
	}
	if (pObject==NULL)
	{
		EMERGENCY_EXIT("Must have pObject value for database resource");
	}
	if ((type==UPDATE_ACTION)&&(pWriteableObject==NULL))
	{
		EMERGENCY_EXIT("Must have pWriteableObject value while update database resource");
	}
	
	switch (type)
	{
	case CREATE_ACTION:
		break;
	case UPDATE_ACTION:
	case DELETE_ACTION:
		pFactory->retrieve(pObject,&writeableObject);
		break;
	default:
		EMERGENCY_EXIT("Invalid resource type");
	}				
}
!!--!!
!!++!!
void C!!@name!!Resource::init(int type, C!!@name!!Factory *pFactory, C!!@name!! *pObject)
{
	m_type=type;
	this->pFactory=pFactory;
	this->ref=pObject;
	switch (type)
	{
	case CREATE_ACTION:
		break;
	case UPDATE_ACTION:
	case DELETE_ACTION:
		pFactory->retrieve(pObject,&writeableObject);
		break;
	default:
		EMERGENCY_EXIT("Invalid resource type");
	}				
}
!!--!!

C!!@name!!Resource::~C!!@name!!Resource(void)
{
}

void C!!@name!!Resource::commit(void)
{
!!if !strcmp(@writeTable,"yes")!!
	switch (m_type)
	{
	case CREATE_ACTION:
		pFactory->commitAdd((C!!@name!! *)ref);
		break;
	case UPDATE_ACTION:
		pFactory->commitUpdate((C!!@name!! *)ref,&writeableObject);	
		break;
	case DELETE_ACTION:
		pFactory->commitRemove(&writeableObject);
		break;
	case NONE_ACTION:
		break;
	default:
		EMERGENCY_EXIT("Invalid resource type");
	}
!!else!
	switch (m_type)
	{
	case CREATE_ACTION:
		pFactory->commitAdd(&writeableObject);
		break;
	default:
		EMERGENCY_EXIT("Invalid resource type");
	}	
!!endif!!
}
	
void C!!@name!!Resource::rollback(void)
{
!!if !strcmp(@writeTable,"yes")!!
	switch (m_type)
	{
	case CREATE_ACTION:
		pFactory->internalRemove((C!!@name!! *)ref,false);
		break;
	case UPDATE_ACTION:
		pFactory->internalUpdate((C!!@name!! *)ref,&writeableObject,false);
		break;
	case DELETE_ACTION:
		pFactory->internalAdd(&writeableObject,false);
		break;
	case NONE_ACTION:
		break;
	default:
		EMERGENCY_EXIT("Invalid resource type");
	}
!!endif!!
}

int C!!@name!!Resource::getPriority(void)
{
	return !!@priority!!;
}

!!++!!
C!!@name!!Factory *C!!@name!!Resource::getFactory(void)
{
	return pFactory;
}
!!--!!
!!endif!!
!!next!!
!!leave!!
