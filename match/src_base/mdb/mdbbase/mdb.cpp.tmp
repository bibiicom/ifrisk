bool CMDB::canSnap()
{
	if (m_MDBLastSnap.m_Status != 0)
		return false;
	return true;
}

bool CMDB::saveSnap()
{
	if (m_MDBLastSnap.m_Status != 1)
		return false;
		
	int dealBegin;
	GET_ACCURATE_MSEC_TIME(dealBegin);	
	PRINT_TO_STD("Begin MDB SaveSnap to %s", m_sLastSnapPath);
	makedir(m_sLastSnapPath);
	char filename[300];
	FILE *output = NULL;
	
	!!travel tables!!
	!!if !strcmp(@hasTable,"yes")!!
		!!if !strcmp(@manager,"Init")!!
	sprintf(filename, "%s!!@name!!.csv", m_sLastSnapPath);
	output = mfopen(filename, "wt");
	if (output == NULL)
		return false;
	CWriteable!!@name!!::writeCSVHead(output);
	vector<CWriteable!!@name!!>::iterator !!@name!!Iter = m_MDBLastSnap.m_!!@name!!.begin();
	while (!!@name!!Iter != m_MDBLastSnap.m_!!@name!!.end())
	{
		!!@name!!Iter->writeCSV(output);
		!!@name!!Iter++;
	}
	fclose(output);
		!!else!!
	if(m_MDBLastSnap.m_!!@name!!.size() > 0)
	{
		sprintf(filename, "%s!!@name!!.csv", m_sLastSnapPath);
		output = mfopen(filename, "wt");
		if (output == NULL)
			return false;
		CWriteable!!@name!!::writeCSVHead(output);
		vector<CWriteable!!@name!!>::iterator !!@name!!Iter = m_MDBLastSnap.m_!!@name!!.begin();
		while (!!@name!!Iter != m_MDBLastSnap.m_!!@name!!.end())
		{
			!!@name!!Iter->writeCSV(output);
			!!@name!!Iter++;
		}
		fclose(output);
	}	
		!!endif!!	
	!!endif!!
	!!next!!
	
	//最后文件显示写入成功
	output = mfopen("dumpPhase.log", "wt");
	fprintf(output, "%.0f", m_nLastSequenceNo);
	fclose(output);
	int dealEnd;
	GET_ACCURATE_MSEC_TIME(dealEnd);
	PRINT_TO_STD("Time MDB SaveSnap is %d ms", dealEnd - dealBegin);
	PRINT_TO_STD("End MDB SaveSnap to %s", m_sLastSnapPath);
	clearSnap();	
	return true;
}
bool CMDB::clearSnap()
{
	!!travel tables!!
	!!if !strcmp(@hasTable,"yes")!!	
	m_MDBLastSnap.m_!!@name!!.clear();
	!!endif!!
	!!next!!
	
	memset(m_sLastSnapPath, 0, sizeof(m_sLastSnapPath));
	m_MDBLastSnap.m_Status = 0;
	m_nLastSequenceNo = 0.0;
	return true;
}

void CMDB::clear()
{
	!!travel tables!!
	!!if !strcmp(@hasTable,"yes")!!
	m_!!@name!!Factory->clearAll();
	!!endif!!
	!!next!!
}

