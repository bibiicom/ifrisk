void CWriteable!!@name!!::writeCSVHead(FILE *output)
{
	fprintf(output,"!!travel fields!!!!if @pumpid!=0!!,!!endif!!\"!!@name!!!!@isPK!!\"!!next!!\n");
}

void CWriteable!!@name!!::writeCSVHeadPreVersion(FILE *output)
{
	fprintf(output,"!!travel fields!!!!if valid_name("preversion")!!!!if strcmp(@preversion,"")!!!!if @pumpid!=0!!,!!endif!!\"!!@preversion!!\"!!endif!!!!else!!!!if @pumpid!=0!!,!!endif!!\"!!@name!!\"!!endif!!!!next!!\n");
}
	
void CWriteable!!@name!!::init()
{
	//初始化的时候已经clear了，这里只需要对notnull的init一下
	!!travel fields!!
		!!if !strcmp(@notnull,"yes")!!
			!!if valid_name("default") && strcmp(@default,"")!!
	!!@name!!.setValue(!!@default!!);
			!!else!!
	!!@name!!.init();
			!!endif!!
		!!else!!
	!!@name!!.clear();
		!!endif!!
	!!next!!
}

void CWriteable!!@name!!::init(CMDB *pMDB)
{
	m_pMDB = pMDB;
	init();
}

int CWriteable!!@name!!::read(FILE *input) 
{
	if (fread(this,1,sizeof(CWriteable!!@name!!),input)!=sizeof(CWriteable!!@name!!))
		return 0;
	else
		return 1;
}
	
int CWriteable!!@name!!::readCSV(FILE *input,vector<char *> *pNames)
{
	char buffer[1025];
	char *token;
	if (fgets(buffer,1024,input)==NULL)
		return 0;
	if (pNames==NULL)
	{
		!!travel fields!!
		!!if @pumpid==0!!
		token=getNextToken(buffer);
		!!else!!
		token=getNextToken(NULL);
		!!endif!!
		if (token!=NULL)
			!!@name!!=token;
		else
			!!@name!!="";
		!!next!!
	}
	else
	{
		init();
		token=getNextToken(buffer);
		int i=0;
		while (token!=NULL)
		{
			char *fieldName;
			fieldName=pNames->at(i);
			if (fieldName==NULL)
			{
				break;
			}
			!!travel fields!!
			!!if @pumpid==0!!
			if (!strcmp(fieldName,"!!@name!!"))
			!!else!!
			else if (!strcmp(fieldName,"!!@name!!"))
			!!endif!!
			{
				!!@name!!=token;
			}
			!!next!!
			i++;
			token=getNextToken(NULL);
		}
	}
	return 1;
}
	
int CWriteable!!@name!!::write(FILE *output) const
{
	if (fwrite(this,1,sizeof(CWriteable!!@name!!),output)!=sizeof(CWriteable!!@name!!))
		return 0;
	else
		return 1;
}

int CWriteable!!@name!!::writeCSV(FILE *output) const
{
	!!travel fields!!
	!!if @pumpid!=0!!
	fprintf(output,",");
	!!endif!!
	fprintf(output,"\"%s\"",!!@name!!.getAllString().c_str());
	!!next!!
	fprintf(output,"\n");
	return 1;
}

int CWriteable!!@name!!::writeCSVPreVersion(FILE *output) const
{
	!!travel fields!!
		!!if valid_name("preversion")!!
			!!if strcmp(@preversion,"")!!
				!!if @pumpid!=0!!
	fprintf(output,",");
				!!endif!!			
	fprintf(output,"\"%s\"",!!@name!!.getAllString().c_str());
			!!endif!!
		!!else!!
			!!if @pumpid!=0!!
	fprintf(output,",");
			!!endif!!		
	fprintf(output,"\"%s\"",!!@name!!.getAllString().c_str());	
		!!endif!!
	!!next!!
	fprintf(output,"\n");
	return 1;
}

