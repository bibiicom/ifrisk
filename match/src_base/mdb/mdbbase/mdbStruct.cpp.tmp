const CWriteable!!@factory!! *CWriteable!!@tableName!!::link!!@name!!() const
{
	void *target=(void *)(&p!!@name!!);
	*((const CWriteable!!@factory!! **)target)=m_pMDB->m_!!@factory!!Factory->find!!@method!!(!!@key!!);
	return p!!@name!!;
}

