void CWriteable!!@name!!::dump(FILE *fp,int index) const
{
	char index_buf[20];
	if(fp==NULL)
		fp=stdout;
	if (index>=0)
		sprintf(index_buf,"[%d]",index);
	else
		index_buf[0]='\0';
	fprintf(fp, "\tC!!@name!!%s = {\n", index_buf);
	!!travel fields!!
	fprintf(fp,"\t\t!!@name!! = %s    [!!@comment!!]\n",!!@name!!.getString().c_str());	
	!!next!!	
	fprintf(fp,"\t}\n");
}

void CWriteable!!@name!!::dumpDiff(FILE *fp, const CWriteable!!@name!! *pOriginal) const
{
	if(fp==NULL)
		fp=stdout;
	fprintf(fp, "\tC!!@name!! = {\n");
	!!travel fields!!
	if (compare(!!@name!!.getValue(),pOriginal->!!@name!!.getValue())!=0)
		fprintf(fp,"\t\t!!@name!! = %s -> %s    [!!@comment!!]\n",pOriginal->!!@name!!.getString().c_str(),!!@name!!.getString().c_str());
	else
		fprintf(fp,"\t\t!!@name!! = %s    [!!@comment!!]\n",!!@name!!.getString().c_str());
	!!next!!	
	fprintf(fp,"\t}\n");
}

void CWriteable!!@name!!::dumpInLine(FILE *fp) const
{
	if(fp==NULL)
		fp=stdout;
	!!travel fields!!
	fprintf(fp,",!!@name!!=%s",!!@name!!.getString().c_str());	
	!!next!!
	fprintf(fp,"\n");
}

void CWriteable!!@name!!::dumpString(char *target) const
{
	char *p=target;
	!!travel fields!!
	sprintf(p,"!!@name!!=%s,",!!@name!!.getString().c_str());
	p+=strlen(p);
	!!next!!
	p--;
	*p='\0';
}

!!if !strcmp(@hasTable,"yes")!!
void C!!@name!!Iterator::dump(FILE *output)
{
	C!!@name!! *p!!@name!!;
	while ((p!!@name!!=next())!=NULL)
	{
		p!!@name!!->dump(output);
	}
}
